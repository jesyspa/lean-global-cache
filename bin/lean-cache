#!/usr/bin/env bash
# lean-cache — manage the shared Lean/mathlib package cache.
#
# The cache is single-writer: every file is owned by OWNER and is NOT
# group-writable, so consumers can only read it and can never clobber it.
# Mutating subcommands (install/uninstall) therefore re-exec themselves as
# OWNER via sudo (see admin/install-sudoers.sh); read-only subcommands
# (link/use/list/resolve) run as any group-member user.
#
# Layout it manages (paths under the configured cache root):
#   <root>/elan/                      ELAN_HOME (lean toolchains)
#   <root>/lakes/<slug>/packages/     per-version package cache
# where <slug> is the toolchain version with dots->dashes, e.g. v4-30-0.
# Default root on the fleet: /opt/bots/lean.
# Default root for a single-user host: $HOME/.local/share/lean-global-cache.
#
# Consumers point a project's .lake/packages symlink at
#   <root>/lakes/<slug>/packages
# (use `lean-cache use` to set that up). Their own build artifacts live in the
# project-local .lake/build, so read-only access to the cache is sufficient.

set -euo pipefail

# --- Config resolution -------------------------------------------------------
# Precedence: env var > /etc/lean-cache.conf (or LEAN_CACHE_CONF) > built-in default.
# This block is inlined (not sourced from lib/config.sh) so the CLI stays a
# single self-contained file installable via `install bin/lean-cache`.

# shellcheck source=/dev/null
[[ -r "${LEAN_CACHE_CONF:-/etc/lean-cache.conf}" ]] \
  && . "${LEAN_CACHE_CONF:-/etc/lean-cache.conf}"

OWNER="${LEAN_CACHE_OWNER:-${OWNER:-$(id -un)}}"
GROUP="${LEAN_CACHE_GROUP:-${GROUP:-$(id -gn)}}"
ROOT="${LEAN_CACHE_ROOT:-${ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/lean-global-cache}}"

SELF="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
BIN="${LEAN_CACHE_BIN:-${BIN:-$SELF}}"

LAKES="$ROOT/lakes"
export ELAN_HOME="$ROOT/elan"
PATH="$ELAN_HOME/bin:$PATH"

# Per-user store of warm PROJECT build artifacts (.lake/build), keyed by
# (repo, commit, toolchain slug). Unlike the mathlib package cache above, this
# is owned by the invoking user, not the shared cache OWNER: a project's
# .lake/build is per-worktree and reproducible, and the worktrees that share it
# all belong to one user. Defaults under the user's cache dir, on the same
# filesystem as the worktrees so artifacts can be hardlinked in. Override with
# LEAN_CACHE_BUILDS (or BUILDS in the config file).
BUILDS="${LEAN_CACHE_BUILDS:-${BUILDS:-${XDG_CACHE_HOME:-$HOME/.cache}/lean-global-cache/builds}}"

# Rotation window for stored builds: the newest build per (repo, toolchain) is
# kept indefinitely (it is "latest main"); any other build published more than
# this many days ago is pruned. Override with LEAN_CACHE_BUILD_KEEP_DAYS.
BUILD_KEEP_DAYS="${LEAN_CACHE_BUILD_KEEP_DAYS:-${BUILD_KEEP_DAYS:-7}}"

# Absolute path the sudoers rule pins; re-exec must use exactly this.
INSTALLED_SELF="$BIN"
# Path the installed hooks invoke to refresh the overlay.
HOOK_BIN="$BIN"

PROG="lean-cache"

# --- Helpers -----------------------------------------------------------------

die()  { echo "$PROG: $*" >&2; exit 1; }
log()  { echo "==> $*" >&2; }

usage() {
  cat >&2 <<EOF
Usage: $PROG <command> [args]

  install <version>     Build & install a mathlib version into the shared cache.
  uninstall <version>   Remove a version from the shared cache.
  link <version>        Print the packages path to symlink a project's
                        .lake/packages at.
  use [version] [path]  Symlink .lake/packages of the project at <path> (default
                        cwd) to the cache. Version defaults to the project's
                        lean-toolchain. Auto-installs the version if it is not
                        in the cache yet (set LEAN_CACHE_AUTO_INSTALL=0 to
                        hard-fail instead). Also installs the overlay git hooks.
  refresh [path]        Re-overlay only if the live overlay's toolchain differs
                        from the project's lean-toolchain (a cheap no-op
                        otherwise). This is what the git hooks call.
  seed-build [path]     Seed .lake/build from a stored warm build when HEAD
                        exactly matches a stored (commit, toolchain) build,
                        replacing any existing build. A no-op when none is
                        stored. Called automatically by \`use\` / \`refresh\` /
                        the post-checkout hook.
  publish-build [path]  Build the project to completion and store its warm
                        .lake/build for the current (commit, toolchain), so
                        future fresh worktrees can be seeded from it.
  prune-builds [--keep-days N]
                        Rotate the warm-build store: keep the newest build per
                        (repo, toolchain) indefinitely, drop any other older than
                        N days (default $BUILD_KEEP_DAYS). Runs after each publish.
  pre-push-gate <remote>
                        Run the push build gate (reads the pushed ref list on
                        stdin). This is what the pre-push git hook calls; not
                        meant to be run by hand.
  fix-filemode          Set core.fileMode=false on every installed package repo
                        so the read-only cache's normalized exec bits stop
                        showing as \`lake build\` "local changes" warnings. New
                        installs do this automatically; this backfills old ones.
  list                  List installed versions with disk usage.
  resolve <version>     Print the normalized toolchain / rev / slug for a
                        version string (no side effects).
  config                Print the four resolved config values (owner/group/root/bin).

Version accepts: 4.30  4.30.0  v4.30.0  leanprover/lean4:v4.30.0  4.30.0-rc2
EOF
  exit "${1:-2}"
}

# Normalize a user-supplied version into its three canonical forms and set the
# globals TCVER (v4.30.0), TOOLCHAIN (leanprover/lean4:v4.30.0), REV (v4.30.0),
# SLUG (v4-30-0). "exact version" policy: major.minor is expanded to
# major.minor.0; anything else is taken verbatim (incl. -rcN suffixes).
normalize_version() {
  local v="$1"
  v="${v#leanprover/lean4:}"   # strip toolchain prefix if present
  v="${v#v}"                   # strip leading v
  [[ -n "$v" ]] || die "empty version"
  # Expand bare major.minor (e.g. 4.30 -> 4.30.0), leaving rc suffixes alone.
  if [[ "$v" =~ ^[0-9]+\.[0-9]+$ ]]; then
    v="$v.0"
  fi
  # Validate: X.Y.Z optionally followed by -rcN / -<word>.
  [[ "$v" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[A-Za-z0-9.]+)?$ ]] \
    || die "not a valid version: '$1'"
  TCVER="v$v"
  TOOLCHAIN="leanprover/lean4:v$v"
  REV="v$v"
  SLUG="v${v//./-}"
}

dest_for()     { echo "$LAKES/$1"; }          # arg: slug
packages_for() { echo "$LAKES/$1/packages"; } # arg: slug

# Stable identity for the repo a worktree belongs to. All worktrees of one repo
# share a common git dir, so its realpath identifies the repo on this host; we
# slugify it as "<workdir-basename>-<short-hash>" so two repos that happen to
# share a basename never collide on one key.
repo_identity() {
  local proj="$1" gitdir
  gitdir="$(git -C "$proj" rev-parse --git-common-dir 2>/dev/null)" || return 1
  [[ "$gitdir" = /* ]] || gitdir="$(cd "$proj" && cd "$gitdir" && pwd)"
  gitdir="$(realpath "$gitdir" 2>/dev/null || echo "$gitdir")"
  local base hash
  base="$(basename "$(dirname "$gitdir")")"
  [[ -n "$base" && "$base" != "." && "$base" != "/" ]] || base="repo"
  hash="$(printf '%s' "$gitdir" | sha1sum | cut -c1-12)"
  printf '%s-%s' "$base" "$hash"
}

# Store dir for a (proj, commit, slug). Echoes the path; nonzero if the repo has
# no identity (not a git repo).
build_store_for() { # args: proj commit slug
  local rid; rid="$(repo_identity "$1")" || return 1
  printf '%s/%s/%s/%s' "$BUILDS" "$rid" "$2" "$3"
}

# Normalize a build-store tree to single-writer read-only: dirs traversable,
# files read-only. The owner can still refresh/remove (it owns the dirs); a
# consumer that hardlinks an artifact in can only read it, so an in-worktree
# edit cannot mutate the shared inode (and a rebuild replaces the link via a
# fresh inode rather than writing through).
normalize_build_store() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0
  find "$dir" -type d -exec chmod u=rwx,go=rx {} +
  find "$dir" -type f -exec chmod a=r {} +
}

# Hardlink (*.olean) or copy (everything else) a build tree from src into dst.
# Oleans are large and are always replaced by `lean` via unlink+create on a
# rebuild, so a read-only hardlink to the shared store is safe and saves the
# disk. The smaller bookkeeping files (.trace/.hash/.setup.json/...) are
# rewritten *in place* by Lake when it rebuilds a module, so they are copied as
# writable, worktree-owned files — never linked back to the shared store.
seed_tree() { # args: src dst
  local src="$1" dst="$2" f rel
  [[ -d "$src" ]] || return 0
  while IFS= read -r -d '' f; do
    rel="${f#"$src"}"; mkdir -p "$dst$(dirname "$rel")"
    if [[ "$f" == *.olean ]]; then
      ln -f "$f" "$dst$rel" 2>/dev/null || { cp -p "$f" "$dst$rel"; chmod u+w "$dst$rel"; }
    else
      cp -p "$f" "$dst$rel"; chmod u+w "$dst$rel"
    fi
  done < <(find "$src" -type f -print0)
}

# Re-exec the current invocation as the cache owner. Used by mutating commands.
require_owner() {
  if [[ "$(id -un)" != "$OWNER" ]]; then
    [[ -x "$INSTALLED_SELF" ]] \
      || die "must run as $OWNER and $INSTALLED_SELF is not installed"
    log "re-executing as $OWNER via sudo"
    exec sudo -n -u "$OWNER" "$INSTALLED_SELF" "$@"
  fi
}

# Force cache contents to: owner-writable, group/other read+traverse only,
# setgid on dirs so new files inherit the group. This is the deterministic pass
# that replaces the per-session umask lottery.
normalize_perms() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0
  chmod -R u=rwX,go=rX "$dir"
  find "$dir" -type d -exec chmod g+s {} +
}

# Tell each cached package repo to ignore file-mode (exec-bit) differences.
# normalize_perms rewrites permissions for single-writer read-only sharing,
# which flips the exec bit on tracked files; without this every `lake build`
# warns that each dependency "has local changes". The bit is meaningless in a
# read-only source cache, so untracking it keeps `git status` clean while still
# surfacing any real content drift from the pinned revision.
ignore_filemode() { # arg: packages dir
  local dir="$1" repo
  [[ -d "$dir" ]] || return 0
  for repo in "$dir"/*/; do
    [[ -e "$repo/.git" ]] || continue
    git -C "$repo" config core.fileMode false
  done
}

# --- Commands ----------------------------------------------------------------

cmd_resolve() {
  [[ $# -eq 1 ]] || usage
  normalize_version "$1"
  echo "toolchain: $TOOLCHAIN"
  echo "rev:       $REV"
  echo "slug:      $SLUG"
  echo "packages:  $(packages_for "$SLUG")"
}

cmd_link() {
  [[ $# -eq 1 ]] || usage
  normalize_version "$1"
  local pkgs; pkgs="$(packages_for "$SLUG")"
  [[ -d "$pkgs" ]] || die "version $TCVER is not installed (no $pkgs)"
  echo "$pkgs"
}

cmd_list() {
  [[ -d "$LAKES" ]] || { echo "(no versions installed)"; return 0; }
  local found=0 d slug
  for d in "$LAKES"/*/; do
    [[ -d "${d}packages" ]] || continue
    slug="$(basename "$d")"
    found=1
    printf '%s\t%s\n' "$(du -sh "${d}packages" 2>/dev/null | cut -f1)" "$slug"
  done
  [[ "$found" -eq 1 ]] || echo "(no versions installed)"
}

# Backfill: set core.fileMode=false on every package repo of every installed
# version. New installs do this automatically; this fixes caches built before
# the setting existed.
cmd_fix_filemode() {
  [[ $# -eq 0 ]] || usage
  require_owner fix-filemode
  [[ -d "$LAKES" ]] || { log "(no versions installed)"; return 0; }
  local d slug found=0
  for d in "$LAKES"/*/; do
    [[ -d "${d}packages" ]] || continue
    slug="$(basename "$d")"; found=1
    log "untracking file-mode in $slug"
    ignore_filemode "${d}packages"
  done
  [[ "$found" -eq 1 ]] || log "(no versions installed)"
}

cmd_install() {
  [[ $# -eq 1 ]] || usage
  normalize_version "$1"
  require_owner install "$1"

  umask 022
  local dest pkgs; dest="$(dest_for "$SLUG")"; pkgs="$(packages_for "$SLUG")"

  if [[ -d "$pkgs" ]]; then
    log "$TCVER already installed at $pkgs (nothing to do)"
    return 0
  fi

  # Serialize installs of the same version.
  mkdir -p "$LAKES"
  exec 9>"$LAKES/.$SLUG.lock"
  flock -n 9 || die "another install of $SLUG is in progress"

  # Clear stale build dirs from a previously-interrupted install of this version
  # (safe under the lock — only this slug's build dirs are touched).
  rm -rf "$LAKES"/.build."$SLUG".* 2>/dev/null || true

  # `elan toolchain install` errors (nonzero) if the toolchain already exists,
  # which would abort under `set -e`; only install when it's actually missing.
  log "ensuring toolchain $TOOLCHAIN"
  if elan toolchain list 2>/dev/null | grep -qxF "$TOOLCHAIN"; then
    log "toolchain $TOOLCHAIN already present"
  else
    elan toolchain install "$TOOLCHAIN"
  fi

  # Build in a temp project on the SAME filesystem as $dest so the final move
  # is atomic. `build` is intentionally NOT `local`: the EXIT trap runs in
  # global scope, where a local would be invisible (and would trip `set -u`).
  build="$(mktemp -d "$LAKES/.build.$SLUG.XXXXXX")"
  trap 'rm -rf "${build:-}"' EXIT

  printf '%s\n' "$TOOLCHAIN" > "$build/lean-toolchain"
  cat > "$build/lakefile.toml" <<EOF
name = "leancache"
defaultTargets = []

[[require]]
name = "mathlib"
git = "https://github.com/leanprover-community/mathlib4"
rev = "$REV"
EOF

  log "resolving mathlib $REV and its dependency closure (lake update)"
  ( cd "$build" && lake update mathlib )

  # `lake update`'s post-update hook already runs a cache fetch, so this explicit
  # `cache get` is often a no-op and can exit nonzero ("No files to download").
  # That's not a failure — the olean integrity check below is the real gate, so
  # don't let a benign nonzero exit abort the install under `set -e`.
  log "fetching prebuilt oleans (lake exe cache get)"
  ( cd "$build" && lake exe cache get ) \
    || log "cache get exited nonzero; verifying oleans directly"

  # Integrity check: mathlib oleans must be present, else the cache is useless.
  # `-print -quit` stops at the first match, so there's no pipe (a `… | head`
  # would SIGPIPE find and, under pipefail+set -e, abort the whole install).
  local first_olean
  first_olean="$(find "$build/.lake/packages/mathlib/.lake/build" -name '*.olean' -print -quit 2>/dev/null)"
  [[ -n "$first_olean" ]] || die "no mathlib oleans after cache get — aborting"

  [[ -d "$build/.lake/packages" ]] \
    || die "lake produced no .lake/packages directory — aborting"

  log "publishing to $pkgs"
  mkdir -p "$dest"
  local incoming="$dest/.packages.incoming.$$"
  rm -rf "$incoming"
  mv "$build/.lake/packages" "$incoming"
  normalize_perms "$incoming"
  ignore_filemode "$incoming"
  mv "$incoming" "$pkgs"          # atomic swap into place

  rm -rf "$build"; trap - EXIT
  normalize_perms "$dest"
  log "installed $TCVER -> $pkgs"
}

cmd_uninstall() {
  [[ $# -eq 1 ]] || usage
  normalize_version "$1"
  require_owner uninstall "$1"

  local dest; dest="$(dest_for "$SLUG")"
  [[ -d "$dest" ]] || { log "$TCVER not installed (nothing to do)"; return 0; }
  local dest_owner; dest_owner="$(stat -c '%U' "$dest")"
  [[ "$dest_owner" == "$OWNER" ]] \
    || die "$dest is owned by $dest_owner, not $OWNER — refusing to remove"
  log "removing $dest"
  rm -rf "$dest"
  log "uninstalled $TCVER"
}

# Build an overlay: .lake/packages is a real directory holding one symlink per
# shared package, leaving the project free to add its own extra packages
# alongside (lake writes those as real dirs). This keeps the shared cache
# read-only while letting projects carry deps beyond mathlib's closure — with
# no risk of cross-project rev conflicts in the shared tree.
cmd_use() {
  # Suppress the overlay hooks for any git command we run while overlaying, so a
  # re-overlay can never recurse back into itself through a ref update.
  export LEAN_CACHE_NO_HOOK=1

  local clean=0 rest=()
  for a in "$@"; do
    case "$a" in
      --clean) clean=1 ;;
      *) rest+=("$a") ;;
    esac
  done
  set -- ${rest[@]+"${rest[@]}"}
  [[ $# -le 2 ]] || usage

  local version="" proj="."
  # Args: [version] [path]. A single arg is a path if it's an existing dir or
  # ".", otherwise a version. (Two args are unambiguous: version then path.)
  if [[ $# -ge 1 ]]; then
    if [[ -d "$1" || "$1" == "." ]]; then proj="$1"
    else version="$1"; fi
  fi
  [[ $# -eq 2 ]] && proj="$2"
  proj="$(cd "$proj" && pwd)" || die "no such directory"

  if [[ -z "$version" ]]; then
    [[ -f "$proj/lean-toolchain" ]] \
      || die "no version given and no $proj/lean-toolchain to derive it from"
    version="$(cat "$proj/lean-toolchain")"
  fi
  normalize_version "$version"
  local shared; shared="$(packages_for "$SLUG")"
  if [[ ! -d "$shared" ]]; then
    # On-demand provisioning: a standalone host installs no versions up front
    # (admin/setup-standalone.sh deliberately skips it), so the first `use` of a
    # toolchain installs it. `install` re-execs as OWNER via the NOPASSWD
    # sudoers rule, so this works for any caller. The hook path never reaches
    # here (cmd_refresh returns early when the version is absent), so a checkout
    # can't trigger a multi-minute build. Set LEAN_CACHE_AUTO_INSTALL=0 to keep
    # the old hard-fail.
    if [[ "${LEAN_CACHE_AUTO_INSTALL:-1}" == 1 ]]; then
      log "$TCVER not installed; provisioning it into the shared cache (first use)"
      "$INSTALLED_SELF" install "$TCVER" \
        || die "auto-install of $TCVER failed; run: $PROG install $TCVER"
      [[ -d "$shared" ]] \
        || die "version $TCVER still not installed after install — aborting"
    else
      die "version $TCVER is not installed; run: $PROG install $TCVER"
    fi
  fi

  local pkgdir="$proj/.lake/packages"
  # Replace a legacy whole-dir symlink, or wipe entirely with --clean.
  if [[ -L "$pkgdir" ]] || { [[ "$clean" -eq 1 && -e "$pkgdir" ]]; }; then
    rm -rf "$pkgdir"
  fi
  mkdir -p "$pkgdir"

  # Drop stale symlinks pointing into any shared cache, so a version switch
  # repoints cleanly and dropped packages disappear. The project's own real
  # package dirs are left untouched.
  local ent
  for ent in "$pkgdir"/* "$pkgdir"/.[!.]*; do
    [[ -L "$ent" && "$(readlink "$ent")" == "$LAKES/"* ]] && rm -f "$ent"
  done

  # Link each shared package in, unless the project already provides its own
  # real directory of that name (an intentional override or extra).
  local pkg name linked=0
  for pkg in "$shared"/*/; do
    name="$(basename "$pkg")"
    [[ -e "$pkgdir/$name" && ! -L "$pkgdir/$name" ]] && continue
    ln -sfn "${pkg%/}" "$pkgdir/$name"
    linked=$((linked + 1))
  done

  log "overlaid $linked shared package(s) into $pkgdir (-> $shared)"
  install_hooks "$proj"
  # Seed a warm project build if one is stored for this exact (commit, slug).
  # A no-op when none is stored.
  cmd_seed_build "$proj" || true
}

# Print the cache slug embedded in the live overlay's mathlib symlink, or
# nothing if the overlay is absent, legacy (a whole-dir symlink), or otherwise
# not pointing into the shared cache. This is the cheap staleness signal the
# hooks rely on: it reads one symlink target and never fetches or guesses.
live_overlay_slug() {
  local link; link="$(readlink "$1/mathlib" 2>/dev/null || true)"
  [[ "$link" == "$LAKES/"* ]] || return 0
  link="${link#"$LAKES"/}"
  printf '%s' "${link%%/*}"
}

# Re-overlay the project only when its live overlay is stale — i.e. points at a
# different toolchain than the one its lean-toolchain now pins (or has no overlay
# yet). On a match this is a one-symlink-read no-op, which is what makes it safe
# to call from a high-frequency hook. A non-Lean project is silently skipped.
cmd_refresh() {
  [[ $# -le 1 ]] || usage
  export LEAN_CACHE_NO_HOOK=1
  local proj="${1:-.}"
  proj="$(cd "$proj" 2>/dev/null && pwd)" || return 0
  [[ -f "$proj/lean-toolchain" ]] || return 0
  normalize_version "$(cat "$proj/lean-toolchain")"
  # Never provision from the hook path: refreshing an overlay to a version that
  # isn't installed is a no-op, not a trigger for a multi-minute build inside a
  # git hook. Direct `use` (not refresh) is what auto-installs.
  [[ -d "$(packages_for "$SLUG")" ]] || return 0
  if [[ "$(live_overlay_slug "$proj/.lake/packages")" == "$SLUG" ]]; then
    # Overlay is already current, so no re-overlay is needed — but a checkout can
    # land HEAD on a published commit without changing the overlay slug, so still
    # try to seed a warm build for the new HEAD.
    cmd_seed_build "$proj" || true
    return 0
  fi
  cmd_use "$proj"   # re-overlays and then seeds
}

# Seed the worktree's .lake/build from a stored warm build, but ONLY when the
# worktree's HEAD exactly matches a stored (commit, slug) build. On any mismatch
# (or no stored build) this is a silent no-op and the normal cold/incremental
# build runs — we never approximate, so we can never replay a stale olean as a
# false green.
#
# When HEAD does match, the stored tree IS the true full build of this exact
# commit, so we replace whatever .lake/build holds (typically a stale leftover
# from a reused worktree) rather than preserving it: the replacement can't be a
# false green (lake re-elaborates any module whose source differs from committed
# HEAD), and preserving a stale build is exactly what forces a needless full
# rebuild. Safe to call from a hook.
cmd_seed_build() {
  [[ $# -le 1 ]] || usage
  local proj="${1:-.}"
  proj="$(cd "$proj" 2>/dev/null && pwd)" || return 0
  [[ -f "$proj/lean-toolchain" ]] || return 0
  local commit; commit="$(git -C "$proj" rev-parse HEAD 2>/dev/null)" || return 0
  [[ -n "$commit" ]] || return 0
  normalize_version "$(cat "$proj/lean-toolchain")"

  local store; store="$(build_store_for "$proj" "$commit" "$SLUG")" || return 0
  [[ -d "$store/lib" ]] || return 0           # no warm build stored for this exact (commit, slug)

  # Safety: only hardlink out of a store we own and that is not group/other
  # writable — otherwise a hardlinked artifact could be mutated underneath a
  # worktree. On any doubt, skip seeding rather than risk a poisoned link.
  local owner; owner="$(stat -c '%U' "$store" 2>/dev/null)"
  [[ "$owner" == "$(id -un)" ]] || { log "build store $store not owned by $(id -un); skipping seed"; return 0; }
  if find "$store" \( -perm -0020 -o -perm -0002 \) -print -quit 2>/dev/null | grep -q .; then
    log "build store $store has group/other-writable files; skipping seed"; return 0
  fi

  # Replace, don't merge: drop any existing lib/ir first so a stale leftover
  # leaves no orphan oleans behind the seeded tree.
  mkdir -p "$proj/.lake/build"
  rm -rf "$proj/.lake/build/lib" "$proj/.lake/build/ir"
  seed_tree "$store/lib" "$proj/.lake/build/lib"
  seed_tree "$store/ir"  "$proj/.lake/build/ir"
  log "seeded warm build for $TCVER @ ${commit:0:12} into $proj/.lake/build"
}

# Build the project to completion and publish its warm .lake/build for the
# current (commit, slug), so future fresh worktrees can be seeded from it.
# Running the build first guarantees we never store a partial or stale tree
# (which would later replay as a false green).
cmd_publish_build() {
  [[ $# -le 1 ]] || usage
  local proj="${1:-.}"
  proj="$(cd "$proj" 2>/dev/null && pwd)" || die "no such directory: ${1:-.}"
  [[ -f "$proj/lean-toolchain" ]] || die "no $proj/lean-toolchain"
  local commit; commit="$(git -C "$proj" rev-parse HEAD 2>/dev/null)" \
    || die "$proj is not a git repository"
  [[ -n "$commit" ]] || die "no HEAD commit in $proj"
  normalize_version "$(cat "$proj/lean-toolchain")"

  log "building $proj to completion before publishing (this can take minutes)"
  ( cd "$proj" && lake build ) || die "lake build failed; refusing to publish a broken build"
  [[ -d "$proj/.lake/build/lib" ]] || die "$proj has no .lake/build/lib to publish"

  local store; store="$(build_store_for "$proj" "$commit" "$SLUG")"
  mkdir -p "$BUILDS"
  exec 9>"$BUILDS/.$(repo_identity "$proj")-$commit-$SLUG.lock" 2>/dev/null \
    || exec 9>"$BUILDS/.publish.lock"
  flock -n 9 || die "another publish for this build is in progress"

  mkdir -p "$(dirname "$store")"
  local incoming="${store}.incoming.$$"
  rm -rf "$incoming"; mkdir -p "$incoming"
  cp -a "$proj/.lake/build/lib" "$incoming/lib"
  [[ -d "$proj/.lake/build/ir" ]] && cp -a "$proj/.lake/build/ir" "$incoming/ir"
  printf 'repo=%s\ncommit=%s\ntoolchain=%s\nslug=%s\noleans=%s\npublished_by=%s\npublished_at=%s\n' \
    "$(repo_identity "$proj")" "$commit" "$TOOLCHAIN" "$SLUG" \
    "$(find "$incoming/lib" -name '*.olean' 2>/dev/null | wc -l)" "$(id -un)" "$(date +%s)" \
    > "$incoming/.seed-manifest"
  normalize_build_store "$incoming"

  rm -rf "$store"
  mv "$incoming" "$store"
  log "published warm build for $TCVER @ ${commit:0:12} -> $store"

  # Rotate this repo's store: the build just published is now "latest" and is
  # kept; older non-latest builds past the window are dropped.
  prune_builds_under "$BUILDS/$(repo_identity "$proj")" "$BUILD_KEEP_DAYS" || true
}

# Epoch at which a stored build was published: from the manifest's published_at,
# else the manifest file's mtime (for entries written before that field existed).
build_published_at() {
  local m="$1/.seed-manifest" t=""
  [[ -f "$m" ]] && t="$(sed -n 's/^published_at=//p' "$m" 2>/dev/null)"
  [[ -n "$t" ]] || t="$(stat -c '%Y' "$m" 2>/dev/null || stat -c '%Y' "$1" 2>/dev/null || echo 0)"
  printf '%s' "$t"
}

# Rotate one repo's store dir ($BUILDS/<repo>): keep the newest build per slug
# (toolchain) indefinitely; remove any other build published more than
# keep_days ago. A build dir is <repo>/<commit>/<slug>.
prune_builds_under() {
  local repo="$1" keep_days="$2"
  [[ -d "$repo" ]] || return 0
  local now cutoff; now="$(date +%s)"; cutoff=$(( now - keep_days * 86400 ))
  local -A latest=()
  local d slug ts
  # Pass 1: newest publish time per slug.
  while IFS= read -r -d '' d; do
    case "$d" in *.incoming.*) continue ;; esac
    [[ -e "$d/.seed-manifest" || -d "$d/lib" ]] || continue
    slug="$(basename "$d")"; ts="$(build_published_at "$d")"
    [[ -z "${latest[$slug]:-}" || "$ts" -gt "${latest[$slug]}" ]] && latest[$slug]="$ts"
  done < <(find "$repo" -mindepth 2 -maxdepth 2 -type d -print0 2>/dev/null)
  # Pass 2: drop non-latest builds older than the window.
  while IFS= read -r -d '' d; do
    case "$d" in *.incoming.*) continue ;; esac
    [[ -e "$d/.seed-manifest" || -d "$d/lib" ]] || continue
    slug="$(basename "$d")"; ts="$(build_published_at "$d")"
    [[ "$ts" -eq "${latest[$slug]:-0}" ]] && continue   # newest per slug: keep
    [[ "$ts" -lt "$cutoff" ]] || continue               # within window: keep
    log "pruning stale build $(basename "$(dirname "$d")")/$slug (~$(( (now - ts) / 86400 ))d old)"
    rm -rf "$d"
  done < <(find "$repo" -mindepth 2 -maxdepth 2 -type d -print0 2>/dev/null)
  # Drop commit dirs left empty by pruning.
  find "$repo" -mindepth 1 -maxdepth 1 -type d -empty -delete 2>/dev/null || true
}

# Rotate every repo's store by the policy above. Safe to run from cron.
cmd_prune_builds() {
  local keep_days="$BUILD_KEEP_DAYS"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keep-days) keep_days="${2:-}"; shift 2 ;;
      --keep-days=*) keep_days="${1#*=}"; shift ;;
      *) usage ;;
    esac
  done
  [[ "$keep_days" =~ ^[0-9]+$ ]] || die "--keep-days must be a non-negative integer"
  [[ -d "$BUILDS" ]] || return 0
  local repo
  for repo in "$BUILDS"/*/; do
    [[ -d "$repo" ]] || continue
    prune_builds_under "${repo%/}" "$keep_days"
  done
}

# Marker on every hook this CLI writes, so a later `use` may regenerate its own
# hooks while never touching a hook some other tool installed.
HOOK_SENTINEL="lean-cache-managed-hook"

# True if $1 is a hook we own: either it carries the current sentinel, or it is
# a pre-sentinel legacy post-checkout hook (recognized by its body) that we
# should upgrade in place.
hook_is_ours() {
  grep -qF "$HOOK_SENTINEL" "$1" 2>/dev/null && return 0
  grep -qF "Re-establish the .lake/packages overlay" "$1" 2>/dev/null
}

# Write our version of a single hook unless a foreign hook already occupies the
# slot. Idempotent: regenerating an unchanged hook leaves identical bytes.
install_one_hook() {
  local hook="$1" body="$2"
  if [[ -e "$hook" ]] && ! hook_is_ours "$hook"; then
    log "leaving foreign hook untouched: $hook"
    return 0
  fi
  printf '%s\n' "$body" > "$hook"
  chmod +x "$hook"
}

# Install the project hooks into the (worktree-shared) hooks directory:
#   post-checkout         — checkout, switch, worktree-add
#   reference-transaction — the only stock hook that also fires on
#                           `git reset --hard` and `git cherry-pick`; it covers
#                           rebase/amend too, so no separate post-rewrite hook
#                           is needed.
#   pre-push              — gate the push on a clean full `lake build`.
# post-checkout / reference-transaction defer to `lean-cache refresh`, whose
# staleness check keeps the high-frequency reference-transaction path a cheap
# no-op. pre-push only runs when the push changes a *.lean file.
install_hooks() {
  local proj="$1" gitdir
  gitdir="$(git -C "$proj" rev-parse --git-common-dir 2>/dev/null)" || return 0
  [[ "$gitdir" = /* ]] || gitdir="$proj/$gitdir"
  mkdir -p "$gitdir/hooks"

  install_one_hook "$gitdir/hooks/post-checkout" "#!/usr/bin/env bash
# $HOOK_SENTINEL: re-establish the .lake/packages overlay after checkout.
[[ -n \"\${LEAN_CACHE_NO_HOOK:-}\" ]] && exit 0
root=\"\$(git rev-parse --show-toplevel 2>/dev/null)\" || exit 0
[[ -f \"\$root/lean-toolchain\" ]] || exit 0
\"\${LEAN_CACHE_BIN:-$HOOK_BIN}\" refresh \"\$root\" >/dev/null 2>&1 || true"

  install_one_hook "$gitdir/hooks/reference-transaction" "#!/usr/bin/env bash
# $HOOK_SENTINEL: re-establish the .lake/packages overlay when HEAD or a local
# branch moves — covers \`git reset --hard\` and \`git cherry-pick\`, which
# post-checkout misses. Drains stdin and acts only on the committed phase for a
# HEAD/branch update, so unrelated ref churn (fetches, tags) stays a no-op.
[[ -n \"\${LEAN_CACHE_NO_HOOK:-}\" ]] && { cat >/dev/null 2>&1; exit 0; }
state=\"\$1\"
relevant=0
while read -r _old _new ref; do
  case \"\$ref\" in HEAD|refs/heads/*) relevant=1 ;; esac
done
[[ \"\$state\" == committed && \"\$relevant\" -eq 1 ]] || exit 0
root=\"\$(git rev-parse --show-toplevel 2>/dev/null)\" || exit 0
[[ -f \"\$root/lean-toolchain\" ]] || exit 0
\"\${LEAN_CACHE_BIN:-$HOOK_BIN}\" refresh \"\$root\" >/dev/null 2>&1 || true"

  install_one_hook "$gitdir/hooks/pre-push" "#!/usr/bin/env bash
# $HOOK_SENTINEL: gate a push on a clean full \`lake build\`. The gate logic
# lives in \`lean-cache pre-push-gate\` (as post-checkout/reference-transaction
# delegate to \`refresh\`) so a fix to the gate reaches every worktree without
# regenerating this hook. Bypass with SKIP_LEAN_PUSH_GATE=1.
[[ -n \"\${SKIP_LEAN_PUSH_GATE:-}\" ]] && exit 0
root=\"\$(git rev-parse --show-toplevel 2>/dev/null)\" || exit 0
[[ -f \"\$root/lakefile.toml\" || -f \"\$root/lakefile.lean\" ]] || exit 0
exec \"\${LEAN_CACHE_BIN:-$HOOK_BIN}\" pre-push-gate \"\$@\""
}

# The push build gate, invoked by the pre-push hook as `pre-push-gate <remote>`
# with the pushed ref list on stdin. Before allowing a push that changes any
# *.lean, bump the mtime of the changed files (so Lake cannot replay a stale
# olean and report a false green) and run the bare default `lake build`; abort
# the push (nonzero exit) if it fails. A full build can take minutes — that
# latency is the intended cost of the gate.
cmd_pre_push_gate() {
  local remote="${1:-}" root changed new base parent f
  root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
  [[ -f "$root/lakefile.toml" || -f "$root/lakefile.lean" ]] || exit 0
  changed=""
  while read -r _lref loid _rref roid; do
    [[ "$loid" =~ ^0+$ ]] && continue
    if [[ "$roid" =~ ^0+$ ]]; then
      base="$(git rev-list "$loid" --not --remotes="$remote" 2>/dev/null | tail -1)"
      [[ -n "$base" ]] || continue
      parent="$(git rev-parse -q --verify "$base^" 2>/dev/null || true)"
      if [[ -n "$parent" ]]; then
        new="$(git diff --name-only "$parent" "$loid" -- '*.lean' 2>/dev/null)"
      else
        new="$(git diff-tree --no-commit-id --name-only -r --root "$loid" -- '*.lean' 2>/dev/null)"
      fi
    else
      new="$(git diff --name-only "$roid" "$loid" -- '*.lean' 2>/dev/null)"
    fi
    changed="$changed$new
"
  done
  changed="$(printf '%s\n' "$changed" | sort -u | sed '/^$/d')"
  [[ -n "$changed" ]] || exit 0
  while IFS= read -r f; do [[ -n "$f" && -f "$root/$f" ]] && touch "$root/$f"; done <<< "$changed"
  command -v lake >/dev/null 2>&1 || { echo 'lean push gate: lake not found in PATH (set SKIP_LEAN_PUSH_GATE=1 to bypass)' >&2; exit 1; }
  echo "lean push gate: $(printf '%s\n' "$changed" | grep -c .) changed .lean file(s); running full 'lake build' (may take minutes)..." >&2
  # Build in a clean git environment. git push from a linked worktree exports
  # GIT_DIR/GIT_WORK_TREE into the hook (and so into here); if Lake inherits
  # them, each 'git remote get-url' it runs to validate a dependency resolves
  # against the superproject instead of the package's own checkout, so Lake sees
  # a bogus URL mismatch and tries to re-clone the (read-only, cache-symlinked)
  # package. Scrubbing the injected vars makes the gate build match a plain
  # interactive lake build.
  ( cd "$root" && env -u GIT_DIR -u GIT_WORK_TREE -u GIT_INDEX_FILE -u GIT_PREFIX \
      -u GIT_COMMON_DIR -u GIT_OBJECT_DIRECTORY -u GIT_QUARANTINE_PATH lake build ) \
    || { echo 'lean push gate: lake build FAILED — push aborted (set SKIP_LEAN_PUSH_GATE=1 to bypass)' >&2; exit 1; }
  echo 'lean push gate: build OK — allowing push' >&2
}

cmd_config() {
  [[ $# -eq 0 ]] || usage
  printf 'owner:  %s\ngroup:  %s\nroot:   %s\nbin:    %s\nbuilds: %s\n' \
    "$OWNER" "$GROUP" "$ROOT" "$BIN" "$BUILDS"
}

# --- Dispatch ----------------------------------------------------------------

[[ $# -ge 1 ]] || usage
cmd="$1"; shift
case "$cmd" in
  install)   cmd_install   "$@" ;;
  uninstall) cmd_uninstall "$@" ;;
  link)      cmd_link      "$@" ;;
  use)          cmd_use           "$@" ;;
  refresh)      cmd_refresh       "$@" ;;
  seed-build)   cmd_seed_build    "$@" ;;
  publish-build) cmd_publish_build "$@" ;;
  prune-builds) cmd_prune_builds  "$@" ;;
  fix-filemode) cmd_fix_filemode  "$@" ;;
  pre-push-gate) cmd_pre_push_gate "$@" ;;
  list)      cmd_list      "$@" ;;
  resolve)   cmd_resolve   "$@" ;;
  config)    cmd_config    "$@" ;;
  -h|--help|help) usage 0 ;;
  *) die "unknown command: $cmd (try --help)" ;;
esac
