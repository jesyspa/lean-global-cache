#!/usr/bin/env bash
# lean-cache — manage the shared Lean/mathlib package cache.
#
# The cache is single-writer: every file is owned by OWNER and is NOT
# group-writable, so consumers can only read it and can never clobber it.
# Mutating subcommands (install/uninstall) therefore re-exec themselves as
# OWNER via sudo (see admin/install-sudoers.sh); read-only subcommands
# (link/use/list/resolve) run as any group-member user.
#
# Layout it manages (paths under the configured cache root):
#   <root>/elan/                      ELAN_HOME (lean toolchains)
#   <root>/lakes/<slug>/packages/     per-version package cache
# where <slug> is the toolchain version with dots->dashes, e.g. v4-30-0.
# Default root on the fleet: /opt/bots/lean.
# Default root for a single-user host: $HOME/.local/share/lean-global-cache.
#
# Consumers point a project's .lake/packages symlink at
#   <root>/lakes/<slug>/packages
# (use `lean-cache use` to set that up). Their own build artifacts live in the
# project-local .lake/build, so read-only access to the cache is sufficient.

set -euo pipefail

# --- Config resolution -------------------------------------------------------
# The single-user default needs no config file at all: the cache is owned by and
# lives under the current user's home. A config file is only for a shared,
# multi-user cache (one writer, many readers). LEAN_CACHE_CONF, if set, is used
# exclusively (a non-existent path selects no config); otherwise read the first
# of these that exists:
#   ~/.config/lean-cache/lean-cache.conf         the owner's config (per-user)
#   /etc/lean-cache/lean-cache.conf              system config (multi-user)
#   /etc/lean-cache.conf                         legacy system config
# This block is inlined (not sourced from lib/config.sh) so the CLI stays a
# single self-contained file installable via `install bin/lean-cache`; keep the
# two in sync.
_conf=""
if [[ -n "${LEAN_CACHE_CONF:-}" ]]; then
  [[ -r "$LEAN_CACHE_CONF" ]] && _conf="$LEAN_CACHE_CONF"
else
  for _c in "${XDG_CONFIG_HOME:-$HOME/.config}/lean-cache/lean-cache.conf" \
            /etc/lean-cache/lean-cache.conf /etc/lean-cache.conf; do
    [[ -r "$_c" ]] && { _conf="$_c"; break; }
  done
fi
# shellcheck source=/dev/null
[[ -n "$_conf" ]] && . "$_conf"
CONFIG_FILE="$_conf"          # the config file in effect, empty if none (check-env reports it)
unset _c _conf

OWNER="${LEAN_CACHE_OWNER:-${OWNER:-$(id -un)}}"
GROUP="${LEAN_CACHE_GROUP:-${GROUP:-$(id -gn)}}"
ROOT="${LEAN_CACHE_ROOT:-${ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/lean-global-cache}}"

SELF="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
BIN="${LEAN_CACHE_BIN:-${BIN:-$SELF}}"

LAKES="$ROOT/lakes"
export ELAN_HOME="$ROOT/elan"
CALLER_PATH="$PATH"          # the caller's PATH, before we prepend the shared elan
PATH="$ELAN_HOME/bin:$PATH"

# Per-user store of warm PROJECT build artifacts (.lake/build), keyed by
# (repo, commit, toolchain slug). Unlike the mathlib package cache above, this
# is owned by the invoking user, not the shared cache OWNER: a project's
# .lake/build is per-worktree and reproducible, and the worktrees that share it
# all belong to one user. Defaults under the user's cache dir, on the same
# filesystem as the worktrees so artifacts can be hardlinked in. Override with
# LEAN_CACHE_BUILDS (or BUILDS in the config file).
BUILDS="${LEAN_CACHE_BUILDS:-${BUILDS:-${XDG_CACHE_HOME:-$HOME/.cache}/lean-global-cache/builds}}"

# Rotation window for stored builds: the newest build per (repo, toolchain) is
# kept indefinitely (it is "latest main"); any other build published more than
# this many days ago is pruned. Override with LEAN_CACHE_BUILD_KEEP_DAYS.
BUILD_KEEP_DAYS="${LEAN_CACHE_BUILD_KEEP_DAYS:-${BUILD_KEEP_DAYS:-7}}"

# Append-only event log (telemetry for the warm-build machinery). The dir is
# shared like the cache, but every user writes only its OWN file
# ($LOG_DIR/events.<user>.log), so the single-writer model holds: one writer per
# file. Same env > config > default precedence as the settings above; deploy.sh
# provisions the dir setgid+sticky so any group member can create its file but
# not remove another's. `stats` reads it; nothing else depends on it.
LOG_DIR="${LEAN_CACHE_LOG_DIR:-${LOG_DIR:-$ROOT/log}}"

# Absolute path the sudoers rule pins; re-exec must use exactly this.
INSTALLED_SELF="$BIN"
# Path the installed hooks invoke to refresh the overlay.
HOOK_BIN="$BIN"

PROG="lean-cache"

# Exit code the cold-build policy uses to bail out of a bounded foreground call
# (CLAUDE_BASH_MODE=foreground) rather than run a multi-minute build that the
# harness would kill mid-flight. Distinct from a build failure (1) so a caller
# can tell "re-run me backgrounded" from "the build broke".
BUILD_BAIL_CODE=75

# --- Helpers -----------------------------------------------------------------

die()  { echo "$PROG: $*" >&2; exit 1; }
log()  { echo "==> $*" >&2; }

# Append one event to this user's log file. Line format (tab-separated):
#   epoch<TAB>user<TAB>event<TAB>key=value<TAB>key=value...
# The whole line is built first and written with a single `>>`. Logging must
# never fail or slow a build, a hook, or a push, so every step is guarded and
# the helper always returns 0: a missing/unwritable dir just drops the event.
# Values are repo slugs, commits, integers, and small enums — none contain a
# tab or newline — so the line stays one field-per-value.
log_event() { # args: event [key=value ...]
  local event="$1"; shift || return 0
  local ts user; ts="$(date +%s 2>/dev/null)" || return 0
  user="$(id -un 2>/dev/null)" || return 0
  local line="$ts"$'\t'"$user"$'\t'"$event" kv
  for kv in "$@"; do line+=$'\t'"$kv"; done
  [[ -d "$LOG_DIR" ]] || mkdir -p "$LOG_DIR" 2>/dev/null || return 0
  printf '%s\n' "$line" >> "$LOG_DIR/events.$user.log" 2>/dev/null || true
  return 0
}

usage() {
  cat >&2 <<EOF
Usage: $PROG <command> [args]

  install [--force] <version>
                        Build & install a mathlib version into the shared cache.
                        --force rebuilds a version already present.
  uninstall <version>   Remove a version from the shared cache.
  set-default-toolchain <version>
                        Set the shared elan's default toolchain — what bare
                        lean/lake use outside a project (inside one, the
                        project's lean-toolchain wins). Must already be installed.
  link <version>        Print the packages path to symlink a project's
                        .lake/packages at.
  use [version] [path]  Symlink .lake/packages of the project at <path> (default
                        cwd) to the cache. Version defaults to the project's
                        lean-toolchain. Auto-installs the version if it is not
                        in the cache yet (set LEAN_CACHE_AUTO_INSTALL=0 to
                        hard-fail instead); in a bounded foreground call
                        (CLAUDE_BASH_MODE=foreground) it bails with re-run
                        instructions rather than start the multi-minute install.
                        Also installs the overlay git hooks.
  refresh [--force-discard] [path]
                        Re-overlay only if the live overlay's toolchain differs
                        from the project's lean-toolchain (a cheap no-op
                        otherwise). This is what the git hooks call. Preserves an
                        existing .lake/build; --force-discard lets seeding
                        replace it with the stored snapshot.
  seed-build [--force-discard] [path]
                        Seed .lake/build from a stored warm build when HEAD
                        exactly matches a stored (commit, toolchain) build. Only
                        warms a cold worktree: a populated .lake/build is left
                        untouched unless --force-discard is given. A no-op when
                        no build is stored. Called automatically by \`use\` /
                        \`refresh\` / the post-checkout hook.
  publish-build [path]  Build the project to completion and store its warm
                        .lake/build for the current (commit, toolchain), so
                        future fresh worktrees can be seeded from it.
  build [--wait] [path] [args]
                        Run \`lake build [args]\` under the shared build policy —
                        the same path bare \`lake build\` takes via the installed
                        \`lake\` shim. Warm/incremental builds run immediately;
                        cold/full builds serialize on a host slot (at most
                        LEAN_CACHE_BUILD_SLOTS, default 2) and run to completion,
                        except in a bounded foreground call (CLAUDE_BASH_MODE=
                        foreground) where they bail with re-run instructions.
                        --wait (or LEAN_CACHE_FORCE_WAIT=1) blocks to completion
                        regardless of mode. A bare-word first arg is a lake
                        target; a path must be \`.\` or contain a slash.
  clean [path]          Remove the worktree's project build (.lake/build) to
                        reset it to a cold state, e.g. before a reused worktree
                        is handed to a new tenant. Leaves the package overlay
                        (.lake/packages) in place. A no-op off a Lake project.
  prune-builds [--keep-days N]
                        Rotate the warm-build store: keep the newest build per
                        (repo, toolchain) indefinitely, drop any other older than
                        N days (default $BUILD_KEEP_DAYS). Runs after each publish,
                        and opportunistically (at most once a day) at the end of
                        \`use\`.
  slots                 Report the state of the host build slots (free/held, and
                        the holder when it can be identified) — answers "why is
                        my build queued". Read-only, no privilege.
  pre-push-gate <remote>
                        Run the push build gate (reads the pushed ref list on
                        stdin). On a clean gate build it also publishes the warm
                        build (set LEAN_CACHE_NO_PUBLISH_ON_PUSH=1 to skip). This
                        is what the pre-push git hook calls; not run by hand.
  commit-hint [path]    Print the post-commit reminder that the warm build can be
                        published for reuse. This is what the post-commit git hook
                        calls; not meant to be run by hand.
  fix-filemode          Set core.fileMode=false on every installed package repo
                        so the read-only cache's normalized exec bits stop
                        showing as \`lake build\` "local changes" warnings. New
                        installs do this automatically; this backfills old ones.
  fix-perms [version]   Re-normalize cache permissions (owner-writable, group/
                        other read-only) over every installed version, or just
                        one. The remedy for verify's group/other-writable FAIL.
                        Owner-only. Covers the lake cache, not elan's tree.
  list                  List installed versions with disk usage.
  resolve <version>     Print the normalized toolchain / rev / slug for a
                        version string (no side effects).
  config                Print the four resolved config values (owner/group/root/bin).
  check-env             Check that this user's environment is wired to the cache
                        (toolchain on PATH, cache readable, repos git-trusted).
  verify                Read-only sweep of the shared cache's invariants: oleans
                        present, no group/other-writable paths, everything owned
                        by OWNER, fileMode untracked, elan toolchains and cache
                        dirs in sync, no stale install scratch. Unprivileged,
                        never mutates anything, cron-friendly. ok/warn/FAIL
                        output like check-env; exits 0 clean or warnings-only,
                        1 on any FAIL.
  stats [--since DAYS]  Summarize the event log over the last DAYS (default 7):
                        per-event counts, seed hit rate, gate outcomes, build
                        durations, slot waits. Read-only, no privilege.

Version accepts: 4.30  4.30.0  v4.30.0  leanprover/lean4:v4.30.0  4.30.0-rc2
EOF
  exit "${1:-2}"
}

# Normalize a user-supplied version into its three canonical forms and set the
# globals TCVER (v4.30.0), TOOLCHAIN (leanprover/lean4:v4.30.0), REV (v4.30.0),
# SLUG (v4-30-0). "exact version" policy: major.minor is expanded to
# major.minor.0; anything else is taken verbatim (incl. -rcN suffixes).
normalize_version() {
  local v="$1"
  v="${v#leanprover/lean4:}"   # strip toolchain prefix if present
  v="${v#v}"                   # strip leading v
  [[ -n "$v" ]] || die "empty version"
  # Expand bare major.minor (e.g. 4.30 -> 4.30.0), leaving rc suffixes alone.
  if [[ "$v" =~ ^[0-9]+\.[0-9]+$ ]]; then
    v="$v.0"
  fi
  # Validate: X.Y.Z optionally followed by -rcN / -<word>.
  [[ "$v" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[A-Za-z0-9.]+)?$ ]] \
    || die "not a valid version: '$1'"
  TCVER="v$v"
  TOOLCHAIN="leanprover/lean4:v$v"
  REV="v$v"
  SLUG="v${v//./-}"
}

dest_for()     { echo "$LAKES/$1"; }          # arg: slug
packages_for() { echo "$LAKES/$1/packages"; } # arg: slug

# True if this `mv` supports --exchange (renameat2 RENAME_EXCHANGE, coreutils
# >=9.5), which atomically swaps two existing paths — used to replace a rebuilt
# package tree with no window where the destination is missing. Memoized.
MV_HAS_EXCHANGE=""
mv_has_exchange() {
  if [[ -z "$MV_HAS_EXCHANGE" ]]; then
    if mv --help 2>/dev/null | grep -q -- '--exchange'; then MV_HAS_EXCHANGE=yes
    else MV_HAS_EXCHANGE=no; fi
  fi
  [[ "$MV_HAS_EXCHANGE" == yes ]]
}

# Stable identity for the repo a worktree belongs to. All worktrees of one repo
# share a common git dir, so its realpath identifies the repo on this host; we
# slugify it as "<workdir-basename>-<short-hash>" so two repos that happen to
# share a basename never collide on one key.
repo_identity() {
  local proj="$1" gitdir
  gitdir="$(git -C "$proj" rev-parse --git-common-dir 2>/dev/null)" || return 1
  [[ "$gitdir" = /* ]] || gitdir="$(cd "$proj" && cd "$gitdir" && pwd)"
  gitdir="$(realpath "$gitdir" 2>/dev/null || echo "$gitdir")"
  local base hash
  base="$(basename "$(dirname "$gitdir")")"
  [[ -n "$base" && "$base" != "." && "$base" != "/" ]] || base="repo"
  hash="$(printf '%s' "$gitdir" | sha1sum | cut -c1-12)"
  printf '%s-%s' "$base" "$hash"
}

# Store dir for a (proj, commit, slug). Echoes the path; nonzero if the repo has
# no identity (not a git repo).
build_store_for() { # args: proj commit slug
  local rid; rid="$(repo_identity "$1")" || return 1
  printf '%s/%s/%s/%s' "$BUILDS" "$rid" "$2" "$3"
}

# Normalize a build-store tree to single-writer read-only: dirs traversable,
# files read-only. The owner can still refresh/remove (it owns the dirs); a
# consumer that hardlinks an artifact in can only read it, so an in-worktree
# edit cannot mutate the shared inode (and a rebuild replaces the link via a
# fresh inode rather than writing through).
normalize_build_store() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0
  find "$dir" -type d -exec chmod u=rwx,go=rx {} +
  find "$dir" -type f -exec chmod a=r {} +
}

# Hardlink (*.olean) or copy (everything else) a build tree from src into dst.
# Oleans are large and are always replaced by `lean` via unlink+create on a
# rebuild, so a read-only hardlink to the shared store is safe and saves the
# disk. The smaller bookkeeping files (.trace/.hash/.setup.json/...) are
# rewritten *in place* by Lake when it rebuilds a module, so they are copied as
# writable, worktree-owned files — never linked back to the shared store.
seed_tree() { # args: src dst
  local src="$1" dst="$2" f rel
  [[ -d "$src" ]] || return 0
  while IFS= read -r -d '' f; do
    rel="${f#"$src"}"; mkdir -p "$dst$(dirname "$rel")"
    if [[ "$f" == *.olean ]]; then
      ln -f "$f" "$dst$rel" 2>/dev/null || { cp -p "$f" "$dst$rel"; chmod u+w "$dst$rel"; }
    else
      cp -p "$f" "$dst$rel"; chmod u+w "$dst$rel"
    fi
  done < <(find "$src" -type f -print0)
}

# True when the worktree already holds compiled build artifacts (oleans) that a
# reseed would overwrite. Seeding warms a *cold* worktree; once a build exists,
# replacing it with the stored snapshot throws away whatever the worktree built
# past that snapshot (a stored non-green build is only a partial). So a reseed
# skips a populated build unless --force-discard is given.
build_populated() { # arg: proj
  [[ -d "$1/.lake/build/lib" ]] || return 1
  find "$1/.lake/build/lib" -name '*.olean' -print -quit 2>/dev/null | grep -q .
}

# True when the worktree carries nothing that could make its build differ from
# a fresh checkout of HEAD: no changes to tracked files and no untracked .lean
# or Lake config files. Untracked files elsewhere (and everything under .lake/)
# cannot enter the build, so they don't count. Only a clean-tree build attests
# the *commit* itself — the gate's skip-on-stored-green relies on this.
tree_clean_for_build() { # arg: proj
  local line
  while IFS= read -r line; do
    case "$line" in
      '') ;;
      '?? .lake/'*) ;;
      '?? '*) case "$line" in
                *.lean|*lakefile.toml|*lakefile.lean|*lean-toolchain) return 1 ;;
              esac ;;
      *) return 1 ;;
    esac
  done < <(git -C "$1" status --porcelain -uall --ignore-submodules 2>/dev/null)
  return 0
}

# Resolve the build-slot count and lock-file base path. Both acquire_build_slot
# and the read-only `slots` command need these, and they must never disagree
# about where the locks live — so this is the one place the strings live.
# Sets BUILD_SLOT_COUNT and BUILD_SLOT_BASE.
build_slot_config() {
  BUILD_SLOT_COUNT="${LEAN_CACHE_BUILD_SLOTS:-${BUILD_SLOTS:-2}}"
  [[ "$BUILD_SLOT_COUNT" =~ ^[0-9]+$ ]] || BUILD_SLOT_COUNT=2
  BUILD_SLOT_BASE="${LEAN_CACHE_BUILD_LOCK_DIR:-${TMPDIR:-/tmp}}/lean-cache-build-slot"
}

# Acquire one of the host-wide build slots (world-openable lock files under
# /tmp), so at most LEAN_CACHE_BUILD_SLOTS heavy `lake build`s run concurrently
# host-wide and each gets real parallelism instead of all of them thrashing a
# few cores. Holds fd 8 until the process exits; exports
# LEAN_CACHE_BUILD_SLOT_HELD so a child build (the gate's publish re-exec)
# rides the parent's slot instead of deadlocking on it. Degrades, never
# blocks work: if no slot frees up within LEAN_CACHE_BUILD_WAIT seconds (or
# the lock files are unusable), the build proceeds unserialized with a note.
# LEAN_CACHE_BUILD_SLOTS=0 disables serialization entirely.
acquire_build_slot() { # arg: message prefix
  [[ -n "${LEAN_CACHE_BUILD_SLOT_HELD:-}" ]] && return 0
  local who="${1:-$PROG}" slots wait base i waited=0
  build_slot_config
  slots="$BUILD_SLOT_COUNT"; base="$BUILD_SLOT_BASE"
  wait="${LEAN_CACHE_BUILD_WAIT:-${BUILD_WAIT:-3600}}"
  [[ "$slots" -gt 0 ]] || return 0
  [[ "$wait" =~ ^[0-9]+$ ]] || wait=3600
  while :; do
    for ((i = 0; i < slots; i++)); do
      # Open the lock coping with fs.protected_regular (>=1; this host runs 1,
      # Arch default is 2). With that sysctl on, opening an *existing* file owned
      # by another user in the sticky world-writable /tmp with O_CREAT fails
      # EACCES even at mode 0666 — so a bot that owns neither slot lock (both
      # created by other users) could otherwise open neither and would silently
      # defeat the whole policy. flock(2) takes LOCK_EX on a read-only fd fine,
      # so open an already-present lock read-only (no O_CREAT); only create an
      # absent one, then chmod it world-writable so the next user can lock it. A
      # lost create race (another user created it just now, so our O_CREAT open
      # of their fresh file EACCESes) falls back to the read-only open. Keep it
      # on fd 8 so run_lake_build's heartbeat can shed the slot with `8>&-`; a
      # dynamic fd would escape that and let an orphaned sleep pin the slot.
      # Brace-group the redirect so the 2>/dev/null scopes to the open alone (a
      # failed exec redirection otherwise kills a non-interactive shell).
      if [[ -e "$base.$i.lock" ]]; then
        { exec 8<"$base.$i.lock"; } 2>/dev/null || continue
      elif { exec 8>>"$base.$i.lock"; } 2>/dev/null; then
        chmod 0666 "$base.$i.lock" 2>/dev/null || true
      else
        { exec 8<"$base.$i.lock"; } 2>/dev/null || continue
      fi
      if flock -n 8; then
        export LEAN_CACHE_BUILD_SLOT_HELD=1
        # Log only a slot that actually waited; the instant-acquire common case
        # is not worth an event.
        [[ "$waited" -eq 0 ]] || { echo "$who: build slot free after ${waited}s — proceeding" >&2; log_event slot wait="$waited" outcome=acquired; }
        return 0
      fi
      exec 8>&-
    done
    if [[ "$waited" -ge "$wait" ]]; then
      echo "$who: no build slot after ${waited}s; proceeding unserialized" >&2
      log_event slot wait="$waited" outcome=unserialized
      return 0
    fi
    if [[ "$waited" -eq 0 ]]; then
      echo "$who: waiting for a host build slot ($slots slot(s), other lake builds running)..." >&2
    elif (( waited % 60 == 0 )); then
      echo "$who: still waiting for a build slot (${waited}s)..." >&2
    fi
    sleep 15; waited=$((waited + 15))
  done
}

# Read-only, unprivileged: report the state of the host build slots — answers
# "why is my build queued". Reuses build_slot_config, so this can never
# disagree with acquire_build_slot about where the locks live or how many
# there are. A slot is "held" when a non-blocking flock probe on its lock file
# fails; the probe opens on a private fd and releases immediately either way,
# so it never leaves a slot held past this command. Best-effort identifies a
# held slot's holder via `fuser -v`, degrading silently when fuser isn't
# installed (or the lock file can't even be opened). Always exits 0.
cmd_slots() {
  [[ $# -eq 0 ]] || usage
  build_slot_config
  local slots="$BUILD_SLOT_COUNT" base="$BUILD_SLOT_BASE"
  if [[ "$slots" -le 0 ]]; then
    echo "build serialization disabled (LEAN_CACHE_BUILD_SLOTS=0)"
    return 0
  fi
  echo "build slots: $slots configured ($base.N.lock)"
  local i lock state holder
  for ((i = 0; i < slots; i++)); do
    lock="$base.$i.lock"
    state="free"; holder=""
    if [[ -e "$lock" ]]; then
      # Open the existing lock read-only (no O_CREAT), so a slot another user
      # holds probes as held rather than "unknown" under fs.protected_regular;
      # flock -n on a read-only fd still reports the state. (acquire_build_slot's
      # comment covers why O_CREAT on another user's file fails there.)
      if { exec 9<"$lock"; } 2>/dev/null; then
        if flock -n 9; then
          flock -u 9
        else
          state="held"
          if command -v fuser >/dev/null 2>&1; then
            holder="$(fuser -v "$lock" 2>&1 | tail -n +2 | head -1 \
                       | sed -e 's/^[^:]*: *//' -e 's/^ *//' -e 's/ *$//')" || true
          fi
        fi
        exec 9>&-
      else
        state="unknown"
      fi
    fi
    if [[ "$state" == held && -n "$holder" ]]; then
      echo "  slot $i: held ($holder)"
    else
      echo "  slot $i: $state"
    fi
  done
  return 0
}

# Resolve the real `lake` binary, skipping our own `lake` shim wherever it sits
# on PATH (the shim carries the LEAN_CACHE_LAKE_SHIM marker; the shim passes its
# already-resolved path down via LEAN_CACHE_REAL_LAKE so we don't re-search).
# Memoized in REAL_LAKE. Without this, `lake build` here would re-enter the shim
# (which sits ahead of the real lake on PATH) and recurse.
REAL_LAKE=""
real_lake() {
  if [[ -z "$REAL_LAKE" ]]; then
    if [[ -n "${LEAN_CACHE_REAL_LAKE:-}" && -x "${LEAN_CACHE_REAL_LAKE:-}" ]]; then
      REAL_LAKE="$LEAN_CACHE_REAL_LAKE"
    else
      local cand
      while IFS= read -r cand; do
        [[ -x "$cand" ]] || continue
        grep -q 'LEAN_CACHE_LAKE_SHIM' "$cand" 2>/dev/null && continue
        REAL_LAKE="$cand"; break
      done < <(type -aP lake 2>/dev/null)
      [[ -n "$REAL_LAKE" ]] || REAL_LAKE="lake"
    fi
  fi
  printf '%s' "$REAL_LAKE"
}

# Run `lake build` in $1 with git's hook-injected environment scrubbed (see
# cmd_pre_push_gate for why) and a heartbeat line every 30s, so a session
# watching a silent non-TTY pipe can tell a minutes-long build is alive.
run_lake_build() { # args: root message-prefix [lake build args...]
  local root="$1" who="$2" pid hb rc=0 lake; shift 2
  lake="$(real_lake)"
  ( cd "$root" && env -u GIT_DIR -u GIT_WORK_TREE -u GIT_INDEX_FILE -u GIT_PREFIX \
      -u GIT_COMMON_DIR -u GIT_OBJECT_DIRECTORY -u GIT_QUARANTINE_PATH "$lake" build "$@" ) &
  pid=$!
  # The heartbeat (and the sleep it is in the middle of when killed) must not
  # inherit our fds: fd 8/9 are the build-slot and publish locks — an orphaned
  # sleep holding them would keep the slot "busy" for up to 30s after the build
  # — and an inherited stdout/stderr would hold a caller's $(...) capture pipe
  # open just as long.
  ( t=0; while sleep 30 >/dev/null 2>&1; do t=$((t + 30)); echo "$who: still building (${t}s)..." >&2; done ) 8>&- 9>&- &
  hb=$!
  wait "$pid" || rc=$?
  kill "$hb" 2>/dev/null || true
  wait "$hb" 2>/dev/null || true
  return "$rc"
}

# True when the project already carries a real prior build: at least one olean
# under .lake/build. A seeded worktree (warm build hardlinked in) counts, so it
# builds incrementally without a slot.
has_local_oleans() { # arg: proj
  local f
  f="$(find "$1/.lake/build" -name '*.olean' -print -quit 2>/dev/null)"
  [[ -n "$f" ]]
}

# True when a stored warm build matches the worktree's exact (HEAD commit,
# toolchain slug) — the same match `seed-build` uses. Runs in a subshell so
# normalize_version's global writes don't leak.
stored_warm_build_matches() { # arg: proj
  local proj="$1" commit slug store
  [[ -f "$proj/lean-toolchain" ]] || return 1
  commit="$(git -C "$proj" rev-parse HEAD 2>/dev/null)" || return 1
  [[ -n "$commit" ]] || return 1
  slug="$( { normalize_version "$(cat "$proj/lean-toolchain")" && printf '%s' "$SLUG"; } 2>/dev/null )" || slug=""
  [[ -n "$slug" ]] || return 1
  store="$(build_store_for "$proj" "$commit" "$slug")" || return 1
  [[ -d "$store/lib" ]]
}

# Classify a build as warm/incremental vs cold/full. "Cold/full" means no stored
# warm build matches HEAD AND .lake/build has no oleans — a from-scratch build
# that thrashes the host. Anything else is warm/incremental (fast, common case).
is_cold_build() { # arg: proj
  has_local_oleans "$1" && return 1
  stored_warm_build_matches "$1" && return 1
  return 0
}

# The shared build policy, used by `lake build` (via the shim, which delegates to
# `lean-cache build`) and by `lean-cache build` directly:
#   - a build riding a parent's slot (LEAN_CACHE_BUILD_SLOT_HELD) completes now,
#     no re-acquire, no bail — the parent already committed to building;
#   - warm/incremental builds run immediately, foreground, NO slot (feel exactly
#     like a plain `lake build`);
#   - cold/full builds serialize on a host slot and run to completion when we can
#     block (force-wait, or a background/absent CLAUDE_BASH_MODE — the wake-on-
#     completion path), but in a bounded foreground call they bail with
#     instructions rather than be killed mid-build.
# RERUN_HINT (set by the caller) is the exact command to re-run on a bail.
run_build_policied() { # args: proj who [lake build args...]
  local proj="$1" who="$2"; shift 2

  if [[ -n "${LEAN_CACHE_BUILD_SLOT_HELD:-}" ]]; then
    run_lake_build "$proj" "$who" "$@"; return
  fi
  if ! is_cold_build "$proj"; then
    run_lake_build "$proj" "$who" "$@"; return
  fi

  # Cold/full from here.
  if [[ -n "${LEAN_CACHE_FORCE_WAIT:-}" ]]; then
    acquire_build_slot "$who"
    run_lake_build "$proj" "$who" "$@"; return
  fi
  if [[ "${CLAUDE_BASH_MODE:-background}" == foreground ]]; then
    {
      echo "$who: cold full build of $proj will exceed this call's ~2-minute foreground limit; not building."
      echo "  Re-run it backgrounded (you'll be woken on completion) or with a 10-minute timeout:"
      echo "    ${RERUN_HINT:-lake build}"
      echo "  Or set LEAN_CACHE_FORCE_WAIT=1 to block to completion regardless of mode."
    } >&2
    log_event bail where=build
    exit "$BUILD_BAIL_CODE"
  fi
  acquire_build_slot "$who"
  run_lake_build "$proj" "$who" "$@"
}

# Re-exec the current invocation as the cache owner. Used by mutating commands.
require_owner() {
  if [[ "$(id -un)" != "$OWNER" ]]; then
    [[ -x "$INSTALLED_SELF" ]] \
      || die "must run as $OWNER and $INSTALLED_SELF is not installed"
    log "re-executing as $OWNER via sudo"
    # sudo keeps the caller's CWD, but the caller often runs from their own
    # home/project tree (mode 700) which $OWNER cannot enter — every CWD-relative
    # `find`/`git` then fails ("Failed to change directory ... Permission
    # denied"). Re-exec from a neutral, world-traversable directory; all work
    # uses absolute paths under the cache root regardless.
    cd / || true
    exec sudo -n -u "$OWNER" "$INSTALLED_SELF" "$@"
  fi
}

# Force cache contents to: owner-writable, group/other read+traverse only,
# setgid on dirs so new files inherit the group. This is the deterministic pass
# that replaces the per-session umask lottery.
normalize_perms() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0
  chmod -R u=rwX,go=rX "$dir"
  find "$dir" -type d -exec chmod g+s {} +
}

# Tell each cached package repo to ignore file-mode (exec-bit) differences.
# normalize_perms rewrites permissions for single-writer read-only sharing,
# which flips the exec bit on tracked files; without this every `lake build`
# warns that each dependency "has local changes". The bit is meaningless in a
# read-only source cache, so untracking it keeps `git status` clean while still
# surfacing any real content drift from the pinned revision.
ignore_filemode() { # arg: packages dir
  local dir="$1" repo
  [[ -d "$dir" ]] || return 0
  for repo in "$dir"/*/; do
    [[ -e "$repo/.git" ]] || continue
    git -C "$repo" config core.fileMode false
  done
}

# Register the shared cache as git-"safe" for the calling user, idempotently.
# The cache is OWNER-owned; when the caller is not OWNER, git aborts any command
# run inside a cache repo with "detected dubious ownership", and Lake misreads
# that failure as the dependency's git URL having changed — so it deletes the
# (read-only, symlinked) package and tries to re-clone it. A single "$LAKES/*"
# entry trusts every repo under the cache root recursively (git's documented
# trailing-/* rule), so it covers packages of versions installed later too,
# without re-registering. The check stays active everywhere outside the cache.
# A no-op for OWNER (who owns the tree) and when the entry is already present.
register_safe_dirs() {
  local glob="$LAKES/*" have
  [[ "$(id -un)" == "$OWNER" ]] && return 0
  command -v git >/dev/null 2>&1 || return 0
  have="$(git config --global --get-all safe.directory 2>/dev/null || true)"
  grep -qxF "$glob" <<<"$have" && return 0
  git config --global --add safe.directory "$glob" 2>/dev/null || true
}

# When the cache uses a shared ELAN_HOME (a fleet/standalone host) rather than
# the caller's own ~/.elan, bare `lean`/`lake` and an editor's Lean server
# resolve elan the usual way — via $HOME/.elan/bin on PATH, or by looking
# straight at ~/.elan — and so miss the shared toolchain. Wire the usual
# location to the shared one by making ~/.elan a symlink to $ELAN_HOME: no rc
# edits, and it also catches tools that hardcode ~/.elan and ignore PATH. The
# shared tree stays owner-only (2755), so this user runs its toolchains
# read-only and cannot pollute it. A real (non-symlink) ~/.elan is never
# clobbered — we warn and leave it, since replacing it needs the user's consent.
# Skipped when the cache IS the caller's own elan (nothing to wire).
wire_elan() {
  local home_elan="$HOME/.elan"
  [[ "$ELAN_HOME" == "$home_elan" ]] && return 0
  # Don't create a dangling link to an elan the owner has not bootstrapped yet.
  [[ -d "$ELAN_HOME" ]] || return 0

  local want; want="$(realpath "$ELAN_HOME" 2>/dev/null || echo "$ELAN_HOME")"

  if [[ -L "$home_elan" ]]; then
    local cur; cur="$(realpath "$home_elan" 2>/dev/null || true)"
    [[ "$cur" == "$want" ]] && return 0          # already wired — stay quiet
    ln -sfn "$ELAN_HOME" "$home_elan"
    log "repointed $home_elan -> $ELAN_HOME (was ${cur:-broken link})"
  elif [[ -e "$home_elan" ]]; then
    # A real personal elan: its bin is on PATH the usual way, so it shadows the
    # shared toolchain. Replacing it would discard the user's own install, so
    # leave it and show how to hand elan over to the cache.
    cat >&2 <<EOF
==> A personal elan at $home_elan is shadowing the shared toolchain.
    To let lean-cache own elan, move it aside and re-run:
        mv $home_elan $home_elan.bak && $PROG use
    That replaces $home_elan with a symlink to the shared $ELAN_HOME; your
    toolchains live in the shared cache, so nothing is lost.
EOF
  else
    ln -sfn "$ELAN_HOME" "$home_elan"
    log "wired $home_elan -> $ELAN_HOME (shared toolchain now on the usual PATH)"
  fi
}

# --- Commands ----------------------------------------------------------------

cmd_resolve() {
  [[ $# -eq 1 ]] || usage
  normalize_version "$1"
  echo "toolchain: $TOOLCHAIN"
  echo "rev:       $REV"
  echo "slug:      $SLUG"
  echo "packages:  $(packages_for "$SLUG")"
}

# Check that the calling user's environment is wired to the cache: the shared
# toolchain is reachable for bare lean/lake and the editor's Lean server, the
# cache is readable, and (for a consumer) its repos are git-trusted so Lake will
# not try to re-clone them. Aimed at a multi-user cache; a single-user cache the
# caller owns passes trivially. Exits non-zero on a hard problem; a warning
# (wiring that only affects interactive/editor use) does not.
cmd_check_env() {
  [[ $# -eq 0 ]] || usage
  local fails=0 warns=0 me; me="$(id -un)"
  pass() { echo "  ok    $*"; }
  warn() { echo "  warn  $*"; warns=$((warns + 1)); }
  fail() { echo "  FAIL  $*"; fails=$((fails + 1)); }

  echo "config      ${CONFIG_FILE:-<none — built-in defaults>}"
  echo "cache root  $ROOT"
  echo "owner       $OWNER   (you are $me)"

  if [[ -d "$LAKES" && -r "$LAKES" ]]; then pass "cache readable"
  elif [[ -e "$LAKES" ]]; then fail "cache $LAKES is not readable"
  else warn "no cache yet at $LAKES (install a version to create it)"; fi

  if [[ -x "$ELAN_HOME/bin/lean" ]]; then pass "shared elan present ($ELAN_HOME)"
  else fail "no elan at $ELAN_HOME — the cache owner must bootstrap it"; fi

  # We prepend the shared elan for our own commands, but bare lean/lake and the
  # editor's Lean server inherit the caller's PATH, so check that. Compare by
  # realpath, not string: `use` wires ~/.elan as a symlink to the shared elan,
  # so the first lean on PATH is $HOME/.elan/bin/lean but resolves to the shared
  # one — that is correctly wired, not a shadow.
  local first_lean; first_lean="$(PATH="$CALLER_PATH" command -v lean 2>/dev/null || true)"
  local want_lean; want_lean="$(realpath "$ELAN_HOME/bin/lean" 2>/dev/null || echo "$ELAN_HOME/bin/lean")"
  local got_lean=""
  [[ -n "$first_lean" ]] && got_lean="$(realpath "$first_lean" 2>/dev/null || echo "$first_lean")"
  if [[ -n "$got_lean" && "$got_lean" == "$want_lean" ]]; then pass "bare lean/lake resolve to the shared elan"
  elif [[ -z "$first_lean" ]]; then
    warn "shared elan not on your PATH; run '$PROG use' to link ~/.elan to it, or add: export PATH=\"$ELAN_HOME/bin:\$PATH\""
  else
    warn "bare lean resolves to $first_lean, not the shared elan; run '$PROG use' to link ~/.elan to the shared elan"
  fi

  # Consumer git-trust: without it Lake mistakes the OWNER-owned dep repos for a
  # changed URL and re-clones. `use` registers these; the OWNER needs nothing.
  if [[ "$me" != "$OWNER" ]]; then
    local anyrepo; anyrepo="$(find "$LAKES" -maxdepth 4 -name .git -printf '%h\n' -quit 2>/dev/null || true)"
    if [[ -z "$anyrepo" ]]; then :
    elif git -C "$anyrepo" rev-parse --git-dir >/dev/null 2>&1; then pass "cache repos are git-trusted (no re-clone)"
    else warn "cache repos not git-trusted; run 'lean-cache use' in a project, or: git config --global --add safe.directory \"$LAKES/*\""; fi
  fi

  if grep -q 'LEAN_CACHE_LAKE_SHIM' "$(dirname "$BIN")/lake" 2>/dev/null; then
    echo "lake shim   installed"
  else
    echo "lake shim   off (bare 'lake build' is unpoliced; use 'lean-cache build' for the slot policy)"
  fi

  echo
  if [[ "$fails" -gt 0 ]]; then echo "$fails problem(s), $warns warning(s)"; return 1; fi
  [[ "$warns" -gt 0 ]] && echo "$warns warning(s)" || echo "all wired up"
  return 0
}

# Read-only invariant sweep over the shared cache itself (as opposed to
# check-env, which checks the calling user's wiring to it). Unprivileged,
# mutates nothing, safe to cron. ok/warn/FAIL output mirrors check-env; exits
# 0 when clean or warnings-only, 1 on any FAIL.
cmd_verify() {
  [[ $# -eq 0 ]] || usage
  local fails=0 warns=0
  pass() { echo "  ok    $*"; }
  warn() { echo "  warn  $*"; warns=$((warns + 1)); }
  fail() { echo "  FAIL  $*"; fails=$((fails + 1)); }

  echo "cache root  $ROOT"

  # 1. Oleans present: every installed version must actually carry mathlib
  # oleans, or a consumer's build fails outright. Same find-one-olean pattern
  # cmd_install's own integrity check uses.
  local -a slugs=()
  if [[ -d "$LAKES" ]]; then
    local d slug mlbuild first_olean
    for d in "$LAKES"/*/; do
      [[ -d "${d}packages" ]] || continue
      slug="$(basename "$d")"; slugs+=("$slug")
      mlbuild="${d}packages/mathlib/.lake/build"
      first_olean="$(find "$mlbuild" -name '*.olean' -print -quit 2>/dev/null || true)"
      if [[ -n "$first_olean" ]]; then pass "$slug: mathlib oleans present"
      else fail "$slug: no mathlib oleans under $mlbuild"; fi
    done
    [[ "${#slugs[@]}" -gt 0 ]] || pass "no versions installed"
  else
    warn "no cache yet at $LAKES (install a version to create it)"
  fi

  # 2. Permissions: the single-writer invariant itself — nothing under the
  # cache may be group- or other-writable. Same -perm tests cmd_seed_build
  # uses to vouch for the (separate) build store.
  local wpath
  wpath="$(find "$LAKES" "$ELAN_HOME" \( -perm -0020 -o -perm -0002 \) -print -quit 2>/dev/null || true)"
  if [[ -n "$wpath" ]]; then fail "group/other-writable path under the cache: $wpath (run '$PROG fix-perms' to re-normalize)"
  else pass "no group/other-writable paths under \$LAKES or \$ELAN_HOME"; fi

  # 3. Ownership: everything under the cache must be owned by $OWNER, or a
  # consumer's read depends on some other user's session/umask/lifetime —
  # the exact "permission lottery" the single-writer model exists to end.
  local opath
  opath="$(find "$LAKES" "$ELAN_HOME" -not -user "$OWNER" -print -quit 2>/dev/null || true)"
  if [[ -n "$opath" ]]; then fail "path not owned by $OWNER: $opath"
  else pass "everything under the cache is owned by $OWNER"; fi

  # 4. fileMode untracked: install sets core.fileMode=false on every package
  # repo (fix-filemode backfills older caches); without it, normalize_perms'
  # exec-bit flip makes every consumer build spam "local changes" warnings.
  local s repo bad
  for s in "${slugs[@]}"; do
    bad=0
    for repo in "$LAKES/$s/packages"/*/; do
      [[ -e "$repo/.git" ]] || continue
      [[ "$(git -C "$repo" config --get core.fileMode 2>/dev/null)" == false ]] || bad=1
    done
    [[ "$bad" -eq 0 ]] || warn "$s: core.fileMode not set on every package repo; run '$PROG fix-filemode'"
  done

  # 5. Orphans: an elan toolchain with no matching cache dir, or a cache dir
  # with no matching toolchain, each mean install/uninstall left the two out
  # of sync. Only leanprover/lean4:v* entries count; elan's " (default)"
  # suffix is stripped before matching.
  local -A tc_slug=()
  local line
  while IFS= read -r line; do
    line="${line% (default)}"
    case "$line" in leanprover/lean4:v*) ;; *) continue ;; esac
    s="$( { normalize_version "$line" && printf '%s' "$SLUG"; } 2>/dev/null )" || continue
    tc_slug["$s"]="$line"
  done < <(elan toolchain list 2>/dev/null || true)
  for s in "${!tc_slug[@]}"; do
    [[ -d "$LAKES/$s/packages" ]] \
      || warn "orphan elan toolchain ${tc_slug[$s]}: no matching cache at $LAKES/$s/packages (run '$PROG install <version>' to add it, or remove the toolchain with elan)"
  done
  for s in "${slugs[@]}"; do
    [[ -n "${tc_slug[$s]:-}" ]] \
      || warn "orphan cache dir $LAKES/$s: no matching elan toolchain (run '$PROG install <version>' to add it, or '$PROG uninstall <version>' to remove the orphaned cache)"
  done

  # 6. Stale scratch: leftovers from an install interrupted mid-flight
  # (cmd_install's own .build.<slug>.* and .packages.incoming/old.* dirs). A
  # fresh one may be an in-flight install, so only flag entries over a day old.
  local now p mtime age; now="$(date +%s)"
  for p in "$LAKES"/.build.* "$LAKES"/*/.packages.incoming.* "$LAKES"/*/.packages.old.*; do
    [[ -e "$p" ]] || continue
    mtime="$(stat -c '%Y' "$p" 2>/dev/null || echo "$now")"
    age=$(( now - mtime ))
    [[ "$age" -gt 86400 ]] \
      && warn "stale install scratch: $p (~$(( age / 86400 ))d old; a fresh one may be an in-flight install)"
  done

  echo
  local ok=1; [[ "$fails" -eq 0 ]] || ok=0
  log_event verify fails="$fails" warns="$warns" ok="$ok"
  if [[ "$fails" -gt 0 ]]; then echo "$fails problem(s), $warns warning(s)"; return 1; fi
  [[ "$warns" -gt 0 ]] && echo "$warns warning(s)" || echo "all clean"
  return 0
}

cmd_link() {
  [[ $# -eq 1 ]] || usage
  normalize_version "$1"
  local pkgs; pkgs="$(packages_for "$SLUG")"
  [[ -d "$pkgs" ]] || die "version $TCVER is not installed (no $pkgs)"
  echo "$pkgs"
}

cmd_list() {
  [[ -d "$LAKES" ]] || { echo "(no versions installed)"; return 0; }
  local found=0 d slug
  for d in "$LAKES"/*/; do
    [[ -d "${d}packages" ]] || continue
    slug="$(basename "$d")"
    found=1
    printf '%s\t%s\n' "$(du -sh "${d}packages" 2>/dev/null | cut -f1)" "$slug"
  done
  [[ "$found" -eq 1 ]] || echo "(no versions installed)"
}

# Backfill: set core.fileMode=false on every package repo of every installed
# version. New installs do this automatically; this fixes caches built before
# the setting existed.
cmd_fix_filemode() {
  [[ $# -eq 0 ]] || usage
  require_owner fix-filemode
  [[ -d "$LAKES" ]] || { log "(no versions installed)"; return 0; }
  local d slug found=0
  for d in "$LAKES"/*/; do
    [[ -d "${d}packages" ]] || continue
    slug="$(basename "$d")"; found=1
    log "untracking file-mode in $slug"
    ignore_filemode "${d}packages"
  done
  [[ "$found" -eq 1 ]] || log "(no versions installed)"
}

# Re-run normalize_perms over installed versions to repair permission drift —
# the single-writer remedy verify's group/other-writable FAIL points at (a
# stray group-writable file that crept into a version tree). Owner-only, like
# fix-filemode, so it re-execs as OWNER on a multi-user host. Covers $LAKES
# only: elan manages its own tree, so normalizing $ELAN_HOME wholesale is
# riskier than the drift is worth. With a version argument it normalizes just
# that version's dir; with none, every installed version.
cmd_fix_perms() {
  [[ $# -le 1 ]] || usage
  local target="" ver_arg=()
  if [[ $# -eq 1 ]]; then normalize_version "$1"; target="$SLUG"; ver_arg=("$1"); fi
  require_owner fix-perms ${ver_arg[@]+"${ver_arg[@]}"}
  umask 022
  if [[ -n "$target" ]]; then
    local dir="$LAKES/$target"
    [[ -d "$dir" ]] || die "version $TCVER is not installed (no $dir)"
    log "normalizing permissions in $target"
    normalize_perms "$dir"
    return 0
  fi
  [[ -d "$LAKES" ]] || { log "(no versions installed)"; return 0; }
  local d slug found=0
  for d in "$LAKES"/*/; do
    [[ -d "${d}packages" ]] || continue
    slug="$(basename "$d")"; found=1
    log "normalizing permissions in $slug"
    normalize_perms "${d%/}"
  done
  [[ "$found" -eq 1 ]] || log "(no versions installed)"
}

# EXIT-trap body for cmd_install: clean the temp build tree and log the install
# event with ok reflecting the exit status, so a failed install (any `die`)
# records ok=0. Reads the INSTALL_* globals cmd_install sets — the trap fires in
# global scope after cmd_install has returned, where its locals are gone (the
# same reason `build` is a global).
_install_exit() {
  local rc=$?
  rm -rf "${build:-}"
  local ok=1; [[ "$rc" -eq 0 ]] || ok=0
  log_event install slug="${INSTALL_SLUG:-}" secs="$(( $(date +%s) - ${INSTALL_T0:-0} ))" \
    ok="$ok" forced="${INSTALL_FORCED:-0}"
}

cmd_install() {
  local force=0 rest=()
  for a in "$@"; do
    case "$a" in
      --force) force=1 ;;
      *) rest+=("$a") ;;
    esac
  done
  set -- ${rest[@]+"${rest[@]}"}
  [[ $# -eq 1 ]] || usage
  normalize_version "$1"
  local force_arg=()
  [[ "$force" -eq 1 ]] && force_arg=(--force)
  require_owner install ${force_arg[@]+"${force_arg[@]}"} "$1"

  umask 022
  local dest pkgs; dest="$(dest_for "$SLUG")"; pkgs="$(packages_for "$SLUG")"

  if [[ -d "$pkgs" && "$force" -eq 0 ]]; then
    log "$TCVER already installed at $pkgs (nothing to do; pass --force to rebuild)"
    return 0
  fi
  [[ "$force" -eq 1 && -d "$pkgs" ]] && log "$TCVER already installed; --force: rebuilding"

  # Event-log context for the EXIT trap below. Globals on purpose: the trap fires
  # in global scope (after cmd_install returns), where a local would be invisible
  # — the same reason `build` below is global. The trap logs the install event on
  # every exit path, so a failure (any `die`) records ok=0 as well.
  INSTALL_SLUG="$SLUG"; INSTALL_FORCED="$force"; INSTALL_T0="$(date +%s)"

  # Serialize installs of the same version.
  mkdir -p "$LAKES"
  exec 9>"$LAKES/.$SLUG.lock"
  flock -n 9 || die "another install of $SLUG is in progress"

  # Clear stale build dirs and half-published trees from a previously-interrupted
  # install of this version (safe under the lock — only this slug's scratch dirs
  # are touched; the live $pkgs is never matched by these globs).
  rm -rf "$LAKES"/.build."$SLUG".* 2>/dev/null || true
  rm -rf "$dest"/.packages.incoming.* "$dest"/.packages.old.* 2>/dev/null || true

  # The install-time replay build (lake build Mathlib widgetJsAll) is a cold
  # from-scratch build — as thrash-prone as any `lean-cache build`, and reached
  # not just by hand but by `use`'s auto-install and deploy.sh's versions
  # reconcile. Take a host build slot so it serializes with policied cold builds
  # instead of stacking on top of them. Held (fd 8) until this process exits;
  # a nested install riding a parent's slot (LEAN_CACHE_BUILD_SLOT_HELD) skips
  # re-acquiring, so a `use`-triggered auto-install during a slotted build never
  # deadlocks. Degrades to unserialized, never blocks (see acquire_build_slot).
  acquire_build_slot "$PROG install $TCVER"

  # `elan toolchain install` errors (nonzero) if the toolchain already exists,
  # which would abort under `set -e`; only install when it's actually missing.
  # elan suffixes the default toolchain with " (default)", so strip that before
  # the exact match or an installed default would be "missing" and re-installed.
  log "ensuring toolchain $TOOLCHAIN"
  if elan toolchain list 2>/dev/null | sed 's/ (default)$//' | grep -qxF "$TOOLCHAIN"; then
    log "toolchain $TOOLCHAIN already present"
  else
    elan toolchain install "$TOOLCHAIN"
  fi

  # Build in a temp project on the SAME filesystem as $dest so the final move
  # is atomic. `build` is intentionally NOT `local`: the EXIT trap runs in
  # global scope, where a local would be invisible (and would trip `set -u`).
  build="$(mktemp -d "$LAKES/.build.$SLUG.XXXXXX")"
  trap _install_exit EXIT

  printf '%s\n' "$TOOLCHAIN" > "$build/lean-toolchain"
  cat > "$build/lakefile.toml" <<EOF
name = "leancache"
defaultTargets = []

[[require]]
name = "mathlib"
git = "https://github.com/leanprover-community/mathlib4"
rev = "$REV"
EOF

  log "resolving mathlib $REV and its dependency closure (lake update)"
  ( cd "$build" && lake update mathlib )

  # `lake update`'s post-update hook already runs a cache fetch, so this explicit
  # `cache get` is often a no-op and can exit nonzero ("No files to download").
  # That's not a failure — the olean integrity check below is the real gate, so
  # don't let a benign nonzero exit abort the install under `set -e`.
  log "fetching prebuilt oleans (lake exe cache get)"
  ( cd "$build" && lake exe cache get ) \
    || log "cache get exited nonzero; verifying oleans directly"

  # Integrity check: mathlib oleans must be present, else the cache is useless.
  # `-print -quit` stops at the first match, so there's no pipe (a `… | head`
  # would SIGPIPE find and, under pipefail+set -e, abort the whole install).
  # `|| true`: a missing dir makes the substitution exit non-zero, which under
  # `set -e` would abort before the `|| die` below can report.
  local mlbuild="$build/.lake/packages/mathlib/.lake/build" first_olean
  first_olean="$(find "$mlbuild" -name '*.olean' -print -quit 2>/dev/null || true)"
  if [[ -z "$first_olean" ]]; then
    log "diagnostic: $mlbuild -> $(ls -d "$mlbuild" 2>&1)"
    log "diagnostic: .lake/packages -> $(ls "$build/.lake/packages" 2>&1 | tr '\n' ' ')"
    die "no mathlib oleans after cache get (looked under $mlbuild) — aborting"
  fi

  [[ -d "$build/.lake/packages" ]] \
    || die "lake produced no .lake/packages directory — aborting"

  # Build fully, as OWNER, rather than trusting `cache get` alone: `cache get`
  # leaves outputs Lake regenerates on a consumer's first build — some hash
  # markers, and ProofWidgets' widget JS — which then fail to write into the
  # read-only cache. This replays the fetched oleans (no recompilation) but
  # rewrites many small files, so it is not instant. Fatal on failure: a cache
  # that breaks consumer builds is worse than none.
  local -a targets=(Mathlib)
  [[ -d "$build/.lake/packages/proofwidgets" ]] && targets+=(widgetJsAll)
  log "building the cache: lake build ${targets[*]} (may take minutes)"
  ( cd "$build" && lake build "${targets[@]}" ) \
    || die "lake build failed — aborting so the cache is not published half-built"

  log "publishing to $pkgs"
  mkdir -p "$dest"
  local incoming="$dest/.packages.incoming.$$"
  rm -rf "$incoming"
  mv "$build/.lake/packages" "$incoming"
  normalize_perms "$incoming"
  ignore_filemode "$incoming"
  # A --force rebuild finds $pkgs already populated; swap the new tree in and
  # drop the old one. `mv --exchange` swaps the two trees in a single atomic
  # renameat2, so a concurrent reader never sees $pkgs missing (nor a dangling
  # overlay symlink through it). Where --exchange is unsupported, fall back to
  # the two-mv sequence, which has a brief window with $pkgs absent.
  if [[ -d "$pkgs" ]]; then
    if mv_has_exchange; then
      # -T so $pkgs (an existing dir) is the swap target itself, not a directory
      # to move $incoming into. After: $pkgs = new tree, $incoming = old tree.
      mv -T --exchange "$incoming" "$pkgs"
      rm -rf "$incoming"
    else
      local old="$dest/.packages.old.$$"
      rm -rf "$old"
      mv "$pkgs" "$old"
      mv "$incoming" "$pkgs"
      rm -rf "$old"
    fi
  else
    mv "$incoming" "$pkgs"          # atomic swap into place
  fi

  rm -rf "$build"
  normalize_perms "$dest"
  log "installed $TCVER -> $pkgs"
  # Leave the EXIT trap set: it fires at process exit with rc=0 and logs the
  # install event (ok=1). $build is already gone, so its rm -rf is a harmless
  # no-op.
}

cmd_uninstall() {
  [[ $# -eq 1 ]] || usage
  normalize_version "$1"
  require_owner uninstall "$1"

  local removed=0

  local dest; dest="$(dest_for "$SLUG")"
  if [[ -d "$dest" ]]; then
    local dest_owner; dest_owner="$(stat -c '%U' "$dest")"
    [[ "$dest_owner" == "$OWNER" ]] \
      || die "$dest is owned by $dest_owner, not $OWNER — refusing to remove"
    log "removing $dest"
    rm -rf "$dest"
    removed=1
  else
    log "$TCVER lake cache not installed (nothing to do)"
  fi

  # elan suffixes the default toolchain with " (default)" in `toolchain list`,
  # so check that exact line before the bare one — matching cmd_install's
  # stripped-suffix lookup would hide which case we're in, and uninstalling the
  # default toolchain breaks elan for every other toolchain too.
  local tc_list; tc_list="$(elan toolchain list 2>/dev/null || true)"
  if printf '%s\n' "$tc_list" | grep -qxF "$TOOLCHAIN (default)"; then
    log "toolchain $TOOLCHAIN is elan's default — skipping removal (uninstalling it would break elan); switch it first with '$PROG set-default-toolchain <other>' if you really want it gone"
  elif printf '%s\n' "$tc_list" | grep -qxF "$TOOLCHAIN"; then
    log "removing toolchain $TOOLCHAIN"
    elan toolchain uninstall "$TOOLCHAIN"
    removed=1
    log "WARNING: any project pinning $TOOLCHAIN via its lean-toolchain file will no longer build until it is reinstalled"
  else
    log "toolchain $TOOLCHAIN not installed (nothing to do)"
  fi

  if [[ "$removed" -eq 1 ]]; then
    log "uninstalled $TCVER"
  else
    log "$TCVER: nothing to do"
  fi
}

# Set the shared elan's default toolchain, i.e. what bare `lean`/`lake`/`elan`
# resolve to *outside* a project (inside one, the project's lean-toolchain always
# wins). Writes settings.toml in the owner-only ELAN_HOME, so it re-execs as
# OWNER. The version must already be installed: `elan default` would otherwise
# download an uncached toolchain into the shared tree, bypassing `install`'s lake
# build and leaving a toolchain with no matching cache — exactly the pollution
# the single-writer model exists to prevent.
cmd_set_default() {
  [[ $# -eq 1 ]] || usage
  normalize_version "$1"
  require_owner set-default-toolchain "$1"

  # elan suffixes the current default with " (default)", so strip it before the
  # exact match (mirrors cmd_install), else an already-default toolchain reads as
  # missing.
  if ! elan toolchain list 2>/dev/null | sed 's/ (default)$//' | grep -qxF "$TOOLCHAIN"; then
    die "$TCVER is not installed; run: $PROG install $TCVER"
  fi
  elan default "$TOOLCHAIN"
  log "default toolchain set to $TOOLCHAIN (bare lean/lake outside a project now use it)"
}

# Build an overlay: .lake/packages is a real directory holding one symlink per
# shared package, leaving the project free to add its own extra packages
# alongside (lake writes those as real dirs). This keeps the shared cache
# read-only while letting projects carry deps beyond mathlib's closure — with
# no risk of cross-project rev conflicts in the shared tree.
cmd_use() {
  # Suppress the overlay hooks for any git command we run while overlaying, so a
  # re-overlay can never recurse back into itself through a ref update.
  export LEAN_CACHE_NO_HOOK=1

  local clean=0 rest=()
  for a in "$@"; do
    case "$a" in
      --clean) clean=1 ;;
      --force-discard) export LEAN_CACHE_FORCE_DISCARD=1 ;;
      *) rest+=("$a") ;;
    esac
  done
  set -- ${rest[@]+"${rest[@]}"}
  [[ $# -le 2 ]] || usage

  local version="" proj="." auto_installed=0
  # Args: [version] [path]. A single arg is a path if it's an existing dir or
  # ".", otherwise a version. (Two args are unambiguous: version then path.)
  if [[ $# -ge 1 ]]; then
    if [[ -d "$1" || "$1" == "." ]]; then proj="$1"
    else version="$1"; fi
  fi
  [[ $# -eq 2 ]] && proj="$2"
  proj="$(cd "$proj" && pwd)" || die "no such directory"

  if [[ -z "$version" ]]; then
    [[ -f "$proj/lean-toolchain" ]] \
      || die "no version given and no $proj/lean-toolchain to derive it from"
    version="$(cat "$proj/lean-toolchain")"
  fi
  normalize_version "$version"
  local shared; shared="$(packages_for "$SLUG")"
  if [[ ! -d "$shared" ]]; then
    # On-demand provisioning: a standalone host installs no versions up front
    # (admin/setup-standalone.sh deliberately skips it), so the first `use` of a
    # toolchain installs it. `install` re-execs as OWNER via the NOPASSWD
    # sudoers rule, so this works for any caller. The hook path never reaches
    # here (cmd_refresh returns early when the version is absent), so a checkout
    # can't trigger a multi-minute build. Set LEAN_CACHE_AUTO_INSTALL=0 to keep
    # the old hard-fail.
    if [[ "${LEAN_CACHE_AUTO_INSTALL:-1}" == 1 ]]; then
      # Auto-install is a multi-minute cold build. In a bounded foreground call
      # (CLAUDE_BASH_MODE=foreground) the harness would kill it mid-flight, so
      # bail like run_build_policied does: don't start it, print the command to
      # run backgrounded / with a long timeout, and exit the distinct bail code.
      # A build riding a parent's slot (LEAN_CACHE_BUILD_SLOT_HELD), force-wait,
      # and background/absent mode all proceed to install.
      if [[ -z "${LEAN_CACHE_BUILD_SLOT_HELD:-}" && -z "${LEAN_CACHE_FORCE_WAIT:-}" \
            && "${CLAUDE_BASH_MODE:-background}" == foreground ]]; then
        {
          echo "$PROG use: $TCVER is not installed; installing it is a multi-minute cold build that would exceed this call's ~2-minute foreground limit, so not starting it here."
          echo "  Install it backgrounded (you'll be woken on completion) or with a 10-minute timeout, then re-run your command:"
          echo "    $PROG install $TCVER"
          echo "  Or set LEAN_CACHE_FORCE_WAIT=1 to install to completion regardless of mode."
        } >&2
        log_event bail where=use
        exit "$BUILD_BAIL_CODE"
      fi
      log "$TCVER not installed; provisioning it into the shared cache (first use)"
      auto_installed=1
      "$INSTALLED_SELF" install "$TCVER" \
        || die "auto-install of $TCVER failed; run: $PROG install $TCVER"
      [[ -d "$shared" ]] \
        || die "version $TCVER still not installed after install — aborting"
    else
      die "version $TCVER is not installed; run: $PROG install $TCVER"
    fi
  fi

  local pkgdir="$proj/.lake/packages"
  # Replace a legacy whole-dir symlink, or wipe entirely with --clean.
  if [[ -L "$pkgdir" ]] || { [[ "$clean" -eq 1 && -e "$pkgdir" ]]; }; then
    rm -rf "$pkgdir"
  fi
  mkdir -p "$pkgdir"

  # Drop stale symlinks pointing into any shared cache, so a version switch
  # repoints cleanly and dropped packages disappear. The project's own real
  # package dirs are left untouched.
  local ent
  for ent in "$pkgdir"/* "$pkgdir"/.[!.]*; do
    [[ -L "$ent" && "$(readlink "$ent")" == "$LAKES/"* ]] && rm -f "$ent"
  done

  # Link each shared package in, unless the project already provides its own
  # real directory of that name (an intentional override or extra).
  local pkg name linked=0
  for pkg in "$shared"/*/; do
    name="$(basename "$pkg")"
    [[ -e "$pkgdir/$name" && ! -L "$pkgdir/$name" ]] && continue
    ln -sfn "${pkg%/}" "$pkgdir/$name"
    linked=$((linked + 1))
  done

  log "overlaid $linked shared package(s) into $pkgdir (-> $shared)"
  # Trust the OWNER-owned cache repos so the calling user's git (and Lake) can
  # read them without a "dubious ownership" abort that triggers a re-clone.
  register_safe_dirs
  install_hooks "$proj"
  # The overlay was (re)built for the acting user, so attribute the event to
  # them; auto_install records whether this use triggered a first-time install
  # (which lands its own install event in OWNER's file).
  log_event use slug="$SLUG" auto_install="$auto_installed"
  # Seed a warm project build if one is stored for this exact (commit, slug).
  # A no-op when none is stored.
  cmd_seed_build "$proj" || true

  # Opportunistic prune: the store is otherwise only rotated by publish-build,
  # so a repo that stops being published to keeps its stale non-latest builds
  # forever unless something crons prune-builds. `use` is a much lower-frequency
  # path than refresh/seed-build (the git-hook path), so piggyback here instead,
  # at most once a day via a stamp file. A fresh stamp is one stat and prints
  # nothing, so this never changes `use`'s output on the common day-fresh path.
  if [[ -d "$BUILDS" ]]; then
    local prune_stamp="$BUILDS/.last-prune" prune_stamp_age
    prune_stamp_age="$(stat -c %Y "$prune_stamp" 2>/dev/null || echo 0)"
    if [[ $(( $(date +%s) - prune_stamp_age )) -ge 86400 ]]; then
      cmd_prune_builds || true
      touch "$prune_stamp" 2>/dev/null || true
    fi
  fi
}

# Print the cache slug embedded in the live overlay's mathlib symlink, or
# nothing if the overlay is absent, legacy (a whole-dir symlink), or otherwise
# not pointing into the shared cache. This is the cheap staleness signal the
# hooks rely on: it reads one symlink target and never fetches or guesses.
live_overlay_slug() {
  local link; link="$(readlink "$1/mathlib" 2>/dev/null || true)"
  [[ "$link" == "$LAKES/"* ]] || return 0
  link="${link#"$LAKES"/}"
  printf '%s' "${link%%/*}"
}

# True when the project's overlay carries a shared-cache symlink that no longer
# resolves — e.g. its target version was `uninstall`ed out from under a
# worktree that still points at it. Only fires when .lake/packages already
# holds an overlay (so a project that has never been `use`d, or one with no
# shared-cache dependency at all, is left alone rather than forced into one).
# This is the cheap presence check `build` runs before every build; it must
# never be fooled by live_overlay_slug's read-the-symlink-text check, which
# can't see a dangling target.
overlay_broken() { # arg: proj
  local pkgdir="$1/.lake/packages" ent
  [[ -d "$pkgdir" ]] || return 1
  for ent in "$pkgdir"/* "$pkgdir"/.[!.]*; do
    [[ -L "$ent" ]] || continue
    case "$(readlink "$ent" 2>/dev/null)" in
      "$LAKES"/*) [[ -e "$ent" ]] || return 0 ;;
    esac
  done
  return 1
}

# Re-overlay the project only when its live overlay is stale — i.e. points at a
# different toolchain than the one its lean-toolchain now pins (or has no overlay
# yet). On a match this is a one-symlink-read no-op, which is what makes it safe
# to call from a high-frequency hook. A non-Lean project is silently skipped.
cmd_refresh() {
  local rest=()
  for a in "$@"; do
    case "$a" in
      --force-discard) export LEAN_CACHE_FORCE_DISCARD=1 ;;
      *) rest+=("$a") ;;
    esac
  done
  set -- ${rest[@]+"${rest[@]}"}
  [[ $# -le 1 ]] || usage
  export LEAN_CACHE_NO_HOOK=1
  local proj="${1:-.}"
  proj="$(cd "$proj" 2>/dev/null && pwd)" || return 0
  [[ -f "$proj/lean-toolchain" ]] || return 0
  normalize_version "$(cat "$proj/lean-toolchain")"
  # Never provision from the hook path: refreshing an overlay to a version that
  # isn't installed is a no-op, not a trigger for a multi-minute build inside a
  # git hook. Direct `use` (not refresh) is what auto-installs.
  [[ -d "$(packages_for "$SLUG")" ]] || return 0
  if [[ "$(live_overlay_slug "$proj/.lake/packages")" == "$SLUG" ]]; then
    # Overlay is already current, so no re-overlay is needed — but a checkout can
    # land HEAD on a published commit without changing the overlay slug, so still
    # try to seed a warm build for the new HEAD.
    cmd_seed_build "$proj" || true
    return 0
  fi
  cmd_use "$proj"   # re-overlays and then seeds
}

# Seed the worktree's .lake/build from a stored build, but ONLY when the
# worktree's HEAD exactly matches a stored (commit, slug) build. On any mismatch
# (or no stored build) this is a silent no-op and the normal cold/incremental
# build runs.
#
# The stored tree is an honest snapshot of this exact commit: every olean is
# paired with its own true trace, so a green publish carries a full build and a
# non-green publish carries a consistent partial one (built pairs up to the
# failure, still-honest older pairs beyond it). lake re-elaborates any module
# whose source or dependencies differ after seeding, so a seeded build can't be
# a false green. Safe to call from a hook.
#
# Seeding only warms a *cold* worktree: if .lake/build already holds compiled
# oleans, this leaves them untouched (a no-op) rather than discard work the
# worktree built past the stored snapshot — a stored non-green build is only a
# partial, so replacing a fuller local build with it is pure loss. Pass
# --force-discard (or set LEAN_CACHE_FORCE_DISCARD=1) to replace an existing
# build with the stored one. When the destructive replace does run, it drops
# .lake/build/lib+ir first so a stale leftover leaves no orphan oleans behind.
cmd_seed_build() {
  local rest=()
  for a in "$@"; do
    case "$a" in
      --force-discard) export LEAN_CACHE_FORCE_DISCARD=1 ;;
      *) rest+=("$a") ;;
    esac
  done
  set -- ${rest[@]+"${rest[@]}"}
  [[ $# -le 1 ]] || usage
  local proj="${1:-.}"
  proj="$(cd "$proj" 2>/dev/null && pwd)" || return 0
  [[ -f "$proj/lean-toolchain" ]] || return 0
  local commit; commit="$(git -C "$proj" rev-parse HEAD 2>/dev/null)" || return 0
  [[ -n "$commit" ]] || return 0
  normalize_version "$(cat "$proj/lean-toolchain")"

  # Never clobber an existing build unless explicitly forced: refresh calls this
  # from the git-hook path on every checkout, and a worktree's own build is work
  # to preserve, not to overwrite.
  if [[ -z "${LEAN_CACHE_FORCE_DISCARD:-}" ]] && build_populated "$proj"; then
    log_event seed hit=0 skip=populated repo="$(repo_identity "$proj")" commit="${commit:0:12}" slug="$SLUG"
    return 0
  fi

  local store; store="$(build_store_for "$proj" "$commit" "$SLUG")" || return 0
  if [[ ! -d "$store/lib" ]]; then            # no warm build stored for this exact (commit, slug)
    log_event seed hit=0 repo="$(repo_identity "$proj")" commit="${commit:0:12}" slug="$SLUG"
    return 0
  fi

  # Safety: only hardlink out of a store we own and that is not group/other
  # writable — otherwise a hardlinked artifact could be mutated underneath a
  # worktree. On any doubt, skip seeding rather than risk a poisoned link.
  local owner; owner="$(stat -c '%U' "$store" 2>/dev/null)"
  [[ "$owner" == "$(id -un)" ]] || { log "build store $store not owned by $(id -un); skipping seed"; return 0; }
  if find "$store" \( -perm -0020 -o -perm -0002 \) -print -quit 2>/dev/null | grep -q .; then
    log "build store $store has group/other-writable files; skipping seed"; return 0
  fi

  # Replace, don't merge: drop any existing lib/ir first so a stale leftover
  # leaves no orphan oleans behind the seeded tree.
  mkdir -p "$proj/.lake/build"
  rm -rf "$proj/.lake/build/lib" "$proj/.lake/build/ir"
  seed_tree "$store/lib" "$proj/.lake/build/lib"
  seed_tree "$store/ir"  "$proj/.lake/build/ir"
  log_event seed hit=1 repo="$(repo_identity "$proj")" commit="${commit:0:12}" slug="$SLUG"
  log "seeded warm build for $TCVER @ ${commit:0:12} into $proj/.lake/build"
}

# Reset a worktree to a cold state by removing its project build (.lake/build),
# so a long-lived worktree reused across tenants does not carry a stale build
# from an earlier commit into the next tenant. The package overlay
# (.lake/packages) is left in place — it is just symlinks the hooks refresh on
# the next checkout, and a later seed/build re-establishes .lake/build. Per-user
# (the worktree's build is owned by the invoking user), so it needs no sudo. A
# silent no-op off a Lake project, so a recycler can call it unconditionally.
cmd_clean() {
  [[ $# -le 1 ]] || usage
  local proj="${1:-.}"
  proj="$(cd "$proj" 2>/dev/null && pwd)" || return 0
  [[ -f "$proj/lakefile.toml" || -f "$proj/lakefile.lean" || -f "$proj/lean-toolchain" ]] || return 0
  [[ -e "$proj/.lake/build" ]] || return 0
  rm -rf "$proj/.lake/build"
  log "removed $proj/.lake/build"
}

# Build the project and publish its .lake/build for the current (commit, slug),
# so future fresh worktrees can be seeded from it. Requires a clean tree, so the
# stored build is an honest snapshot of committed sources; tree_clean=1 in the
# manifest records that lake exited 0 (a green build the gate may skip on). A
# non-green build is still published (tree_clean=0) to seed future incremental
# builds, but never overwrites a stored green build of the same commit.
cmd_publish_build() {
  [[ $# -le 1 ]] || usage
  # Publishing must build synchronously; never take the cold-build bail path.
  export LEAN_CACHE_FORCE_WAIT=1
  local proj="${1:-.}"
  proj="$(cd "$proj" 2>/dev/null && pwd)" || die "no such directory: ${1:-.}"
  [[ -f "$proj/lean-toolchain" ]] || die "no $proj/lean-toolchain"
  local commit; commit="$(git -C "$proj" rev-parse HEAD 2>/dev/null)" \
    || die "$proj is not a git repository"
  [[ -n "$commit" ]] || die "no HEAD commit in $proj"
  normalize_version "$(cat "$proj/lean-toolchain")"

  # Publish only at a commit boundary: the working tree must match committed
  # HEAD, so every stored build is an honest snapshot keyed to real committed
  # sources. Publish WIP by committing it first, then publishing.
  tree_clean_for_build "$proj" \
    || die "refusing to publish a dirty tree; commit your changes first"

  local pub_t0; pub_t0="$(date +%s)"
  log "building $proj before publishing (this can take minutes)"
  acquire_build_slot "$PROG publish-build"
  # A failed build is still publishable: its .lake/build holds honest olean/trace
  # pairs for the modules that did compile, which seed a faster incremental build.
  # green (lake exited 0) is what the manifest records as tree_clean.
  local green=0
  if run_lake_build "$proj" "$PROG publish-build"; then green=1; fi
  [[ -d "$proj/.lake/build/lib" ]] || die "$proj has no .lake/build/lib to publish"

  local store; store="$(build_store_for "$proj" "$commit" "$SLUG")"
  mkdir -p "$BUILDS"
  # Brace group, not `exec ... 2>/dev/null`: that would permanently redirect
  # the script's stderr (killing all later log output), and a failed exec
  # redirection exits a non-interactive shell before the || fallback runs.
  { exec 9>"$BUILDS/.$(repo_identity "$proj")-$commit-$SLUG.lock"; } 2>/dev/null \
    || exec 9>"$BUILDS/.publish.lock"
  flock -n 9 || die "another publish for this build is in progress"

  # Never turn a stored green attestation into a non-green one: an interrupted or
  # failed rebuild at a commit already known green must not stale the entry or
  # switch off the gate's skip. Leave the stored green build in place, and never
  # fail the caller (a push must not be affected).
  if [[ "$green" -eq 0 ]] && grep -qx 'tree_clean=1' "$store/.seed-manifest" 2>/dev/null; then
    log_event publish repo="$(repo_identity "$proj")" commit="${commit:0:12}" slug="$SLUG" green="$green" secs=$(( $(date +%s) - pub_t0 ))
    log "keeping stored green build for $TCVER @ ${commit:0:12}; not overwriting with a non-green build"
    return 0
  fi

  mkdir -p "$(dirname "$store")"
  local incoming="${store}.incoming.$$"
  rm -rf "$incoming"; mkdir -p "$incoming"
  cp -a "$proj/.lake/build/lib" "$incoming/lib"
  [[ -d "$proj/.lake/build/ir" ]] && cp -a "$proj/.lake/build/ir" "$incoming/ir"
  printf 'repo=%s\ncommit=%s\ntoolchain=%s\nslug=%s\noleans=%s\npublished_by=%s\npublished_at=%s\ntree_clean=%s\n' \
    "$(repo_identity "$proj")" "$commit" "$TOOLCHAIN" "$SLUG" \
    "$(find "$incoming/lib" -name '*.olean' 2>/dev/null | wc -l)" "$(id -un)" "$(date +%s)" "$green" \
    > "$incoming/.seed-manifest"
  normalize_build_store "$incoming"

  rm -rf "$store"
  mv "$incoming" "$store"
  log_event publish repo="$(repo_identity "$proj")" commit="${commit:0:12}" slug="$SLUG" green="$green" secs=$(( $(date +%s) - pub_t0 ))
  log "published $([[ "$green" -eq 1 ]] && echo green || echo non-green) build for $TCVER @ ${commit:0:12} -> $store"

  # Rotate this repo's store: the build just published is now "latest" and is
  # kept; older non-latest builds past the window are dropped.
  prune_builds_under "$BUILDS/$(repo_identity "$proj")" "$BUILD_KEEP_DAYS" || true
}

# Epoch at which a stored build was published: from the manifest's published_at,
# else the manifest file's mtime (for entries written before that field existed).
build_published_at() {
  local m="$1/.seed-manifest" t=""
  [[ -f "$m" ]] && t="$(sed -n 's/^published_at=//p' "$m" 2>/dev/null)"
  [[ -n "$t" ]] || t="$(stat -c '%Y' "$m" 2>/dev/null || stat -c '%Y' "$1" 2>/dev/null || echo 0)"
  printf '%s' "$t"
}

# True if a stored build dir holds a green (lake-exited-0) build.
build_is_green() { grep -qx 'tree_clean=1' "$1/.seed-manifest" 2>/dev/null; }

# Rotate one repo's store dir ($BUILDS/<repo>): keep the newest build per slug
# (toolchain) AND the newest green build per slug indefinitely; remove any other
# build published more than keep_days ago. Protecting the newest green build
# keeps a stream of non-green WIP publishes from washing out the attestation the
# gate skips on. A build dir is <repo>/<commit>/<slug>.
prune_builds_under() {
  local repo="$1" keep_days="$2"
  [[ -d "$repo" ]] || return 0
  local now cutoff; now="$(date +%s)"; cutoff=$(( now - keep_days * 86400 ))
  local -A latest=() latest_green=()
  local d slug ts
  # Pass 1: newest publish time per slug, and newest green publish time per slug.
  while IFS= read -r -d '' d; do
    case "$d" in *.incoming.*) continue ;; esac
    [[ -e "$d/.seed-manifest" || -d "$d/lib" ]] || continue
    slug="$(basename "$d")"; ts="$(build_published_at "$d")"
    [[ -z "${latest[$slug]:-}" || "$ts" -gt "${latest[$slug]}" ]] && latest[$slug]="$ts"
    if build_is_green "$d"; then
      [[ -z "${latest_green[$slug]:-}" || "$ts" -gt "${latest_green[$slug]}" ]] && latest_green[$slug]="$ts"
    fi
  done < <(find "$repo" -mindepth 2 -maxdepth 2 -type d -print0 2>/dev/null)
  # Pass 2: drop builds that are neither newest-per-slug nor newest-green-per-slug
  # and are older than the window.
  while IFS= read -r -d '' d; do
    case "$d" in *.incoming.*) continue ;; esac
    [[ -e "$d/.seed-manifest" || -d "$d/lib" ]] || continue
    slug="$(basename "$d")"; ts="$(build_published_at "$d")"
    [[ "$ts" -eq "${latest[$slug]:-0}" ]] && continue   # newest per slug: keep
    [[ "$ts" -eq "${latest_green[$slug]:-0}" ]] && build_is_green "$d" && continue  # newest green per slug: keep
    [[ "$ts" -lt "$cutoff" ]] || continue               # within window: keep
    log "pruning stale build $(basename "$(dirname "$d")")/$slug (~$(( (now - ts) / 86400 ))d old)"
    rm -rf "$d"
  done < <(find "$repo" -mindepth 2 -maxdepth 2 -type d -print0 2>/dev/null)
  # Drop commit dirs left empty by pruning.
  find "$repo" -mindepth 1 -maxdepth 1 -type d -empty -delete 2>/dev/null || true
}

# Rotate every repo's store by the policy above. Safe to run from cron.
cmd_prune_builds() {
  local keep_days="$BUILD_KEEP_DAYS"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keep-days) keep_days="${2:-}"; shift 2 ;;
      --keep-days=*) keep_days="${1#*=}"; shift ;;
      *) usage ;;
    esac
  done
  [[ "$keep_days" =~ ^[0-9]+$ ]] || die "--keep-days must be a non-negative integer"
  [[ -d "$BUILDS" ]] || return 0
  local repo
  for repo in "$BUILDS"/*/; do
    [[ -d "$repo" ]] || continue
    prune_builds_under "${repo%/}" "$keep_days"
  done
}

# Marker on every hook this CLI writes, so a later `use` may regenerate its own
# hooks while never touching a hook some other tool installed.
HOOK_SENTINEL="lean-cache-managed-hook"

# True if $1 is a hook we own: either it carries the current sentinel, or it is
# a pre-sentinel legacy post-checkout hook (recognized by its body) that we
# should upgrade in place.
hook_is_ours() {
  grep -qF "$HOOK_SENTINEL" "$1" 2>/dev/null && return 0
  grep -qF "Re-establish the .lake/packages overlay" "$1" 2>/dev/null
}

# Write our version of a single hook unless a foreign hook already occupies the
# slot. Idempotent: regenerating an unchanged hook leaves identical bytes.
install_one_hook() {
  local hook="$1" body="$2"
  if [[ -e "$hook" ]] && ! hook_is_ours "$hook"; then
    log "leaving foreign hook untouched: $hook"
    return 0
  fi
  printf '%s\n' "$body" > "$hook"
  chmod +x "$hook"
}

# Install the project hooks into the (worktree-shared) hooks directory:
#   post-checkout         — checkout, switch, worktree-add
#   reference-transaction — the only stock hook that also fires on
#                           `git reset --hard` and `git cherry-pick`; it covers
#                           rebase/amend too, so no separate post-rewrite hook
#                           is needed.
#   pre-push              — gate the push on a clean full `lake build`, then
#                           publish that warm build for reuse.
#   post-commit           — remind that a *.lean commit's warm build can be
#                           published for reuse.
# post-checkout / reference-transaction defer to `lean-cache refresh`, whose
# staleness check keeps the high-frequency reference-transaction path a cheap
# no-op. pre-push only runs when the push changes a *.lean file; post-commit is a
# no-op on a commit that touches no *.lean.
install_hooks() {
  local proj="$1" gitdir
  gitdir="$(git -C "$proj" rev-parse --git-common-dir 2>/dev/null)" || return 0
  [[ "$gitdir" = /* ]] || gitdir="$proj/$gitdir"
  mkdir -p "$gitdir/hooks"

  install_one_hook "$gitdir/hooks/post-checkout" "#!/usr/bin/env bash
# $HOOK_SENTINEL: re-establish the .lake/packages overlay after checkout.
[[ -n \"\${LEAN_CACHE_NO_HOOK:-}\" ]] && exit 0
root=\"\$(git rev-parse --show-toplevel 2>/dev/null)\" || exit 0
[[ -f \"\$root/lean-toolchain\" ]] || exit 0
\"\${LEAN_CACHE_BIN:-$HOOK_BIN}\" refresh \"\$root\" >/dev/null 2>&1 || true"

  install_one_hook "$gitdir/hooks/reference-transaction" "#!/usr/bin/env bash
# $HOOK_SENTINEL: re-establish the .lake/packages overlay when HEAD or a local
# branch moves — covers \`git reset --hard\` and \`git cherry-pick\`, which
# post-checkout misses. Drains stdin and acts only on the committed phase for a
# HEAD/branch update, so unrelated ref churn (fetches, tags) stays a no-op.
[[ -n \"\${LEAN_CACHE_NO_HOOK:-}\" ]] && { cat >/dev/null 2>&1; exit 0; }
state=\"\$1\"
relevant=0
while read -r _old _new ref; do
  case \"\$ref\" in HEAD|refs/heads/*) relevant=1 ;; esac
done
[[ \"\$state\" == committed && \"\$relevant\" -eq 1 ]] || exit 0
root=\"\$(git rev-parse --show-toplevel 2>/dev/null)\" || exit 0
[[ -f \"\$root/lean-toolchain\" ]] || exit 0
\"\${LEAN_CACHE_BIN:-$HOOK_BIN}\" refresh \"\$root\" >/dev/null 2>&1 || true"

  install_one_hook "$gitdir/hooks/pre-push" "#!/usr/bin/env bash
# $HOOK_SENTINEL: gate a push on a clean full \`lake build\`. The gate logic
# lives in \`lean-cache pre-push-gate\` (as post-checkout/reference-transaction
# delegate to \`refresh\`) so a fix to the gate reaches every worktree without
# regenerating this hook. Bypass with SKIP_LEAN_PUSH_GATE=1.
[[ -n \"\${SKIP_LEAN_PUSH_GATE:-}\" ]] && exit 0
root=\"\$(git rev-parse --show-toplevel 2>/dev/null)\" || exit 0
[[ -f \"\$root/lakefile.toml\" || -f \"\$root/lakefile.lean\" ]] || exit 0
exec \"\${LEAN_CACHE_BIN:-$HOOK_BIN}\" pre-push-gate \"\$@\""

  install_one_hook "$gitdir/hooks/post-commit" "#!/usr/bin/env bash
# $HOOK_SENTINEL: after a commit touching *.lean, remind that its warm build can
# be published for reuse. The hint logic lives in \`lean-cache commit-hint\` (as
# the other hooks delegate to the CLI) so a fix reaches every worktree without
# regenerating this hook. Silence with LEAN_CACHE_NO_COMMIT_HINT=1.
[[ -n \"\${LEAN_CACHE_NO_HOOK:-}\" || -n \"\${LEAN_CACHE_NO_COMMIT_HINT:-}\" ]] && exit 0
root=\"\$(git rev-parse --show-toplevel 2>/dev/null)\" || exit 0
[[ -f \"\$root/lean-toolchain\" ]] || exit 0
exec \"\${LEAN_CACHE_BIN:-$HOOK_BIN}\" commit-hint \"\$root\""
}

# The push build gate, invoked by the pre-push hook as `pre-push-gate <remote>`
# with the pushed ref list on stdin. Before allowing a push that changes any
# *.lean, bump the mtime of the changed files (so Lake cannot replay a stale
# olean and report a false green) and run the bare default `lake build`; abort
# the push (nonzero exit) if it fails. A full build can take minutes — that
# latency is the intended cost of the gate.
#
# The gate can only build the tree it has: the checked-out worktree. A pushed
# ref whose tip is not the worktree's HEAD (e.g. `git push origin other` while
# on main) is therefore NOT gated — the gate warns and lets it pass rather than
# green-lighting `other` on the strength of a build of `main`.
cmd_pre_push_gate() {
  # The gate blocks the push; it must build synchronously to completion and
  # never take the cold-build bail path.
  export LEAN_CACHE_FORCE_WAIT=1
  local remote="${1:-}" root head changed new base parent f tip know
  local gate=0 undecided=0 ungated="" gate_t0=0
  root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
  [[ -f "$root/lakefile.toml" || -f "$root/lakefile.lean" ]] || exit 0
  head="$(git rev-parse -q --verify HEAD 2>/dev/null || true)"
  changed=""
  while read -r lref loid _rref roid; do
    [[ "$loid" =~ ^0+$ ]] && continue          # ref deletion: nothing to build
    new=""; know=1
    if [[ "$roid" =~ ^0+$ ]] || ! new="$(git diff --name-only "$roid" "$loid" -- '*.lean' 2>/dev/null)"; then
      # No remote tip to diff against: the ref is new on the remote, or the
      # remote tip's object is absent locally (a force-push after the remote
      # moved, without fetching). Diff from just below the oldest pushed commit
      # that no remote-tracking ref already has — or from the empty tree when
      # the entire history is new to the remote.
      new=""
      base="$(git rev-list "$loid" --not --remotes="$remote" 2>/dev/null | tail -1)" || base=""
      if [[ -n "$base" ]]; then
        parent="$(git rev-parse -q --verify "$base^" 2>/dev/null || true)"
        [[ -n "$parent" ]] || parent="$(git hash-object -t tree /dev/null)"
        new="$(git diff --name-only "$parent" "$loid" -- '*.lean' 2>/dev/null)" || new=""
      elif [[ ! "$roid" =~ ^0+$ ]]; then
        # Unknown remote tip and every pushed commit is already on some
        # remote-tracking ref (e.g. force-pushing a rollback): what the push
        # changes is undecidable here, so gate it rather than wave it through.
        know=0
      fi
    fi
    [[ -n "$new" || "$know" -eq 0 ]] || continue
    tip="$(git rev-parse -q --verify "$loid^{commit}" 2>/dev/null || true)"
    if [[ -n "$head" && "$tip" == "$head" ]]; then
      gate=1
      [[ "$know" -eq 1 ]] || undecided=1
      changed="$changed$new
"
    else
      ungated="$ungated $lref"
    fi
  done
  [[ -z "$ungated" ]] || echo "lean push gate: WARNING: pushed ref(s)$ungated change .lean but their tip is not the checked-out HEAD; the gate can only build the current worktree, so they are NOT gated. Check the ref out and push from that worktree to gate it." >&2
  [[ "$gate" -eq 1 ]] || exit 0

  # Skip the rebuild when the store already holds a green build of this exact
  # (commit, toolchain): that build attests the commit compiles, so gating it
  # again only repeats minutes of work (the worker-builds / coordinator-verifies
  # / gate-builds-again triple build). A non-green stored build (tree_clean=0, or
  # a manifest predating the field) attests nothing and never skips.
  # Set LEAN_CACHE_NO_GATE_SKIP=1 to force the rebuild.
  if [[ -z "${LEAN_CACHE_NO_GATE_SKIP:-}" && -f "$root/lean-toolchain" ]]; then
    local slug store
    slug="$( { normalize_version "$(cat "$root/lean-toolchain")" && printf '%s' "$SLUG"; } 2>/dev/null )" || slug=""
    if [[ -n "$slug" ]] && store="$(build_store_for "$root" "$head" "$slug")" \
       && [[ -d "$store/lib" ]] \
       && [[ "$(stat -c '%U' "$store" 2>/dev/null)" == "$(id -un)" ]] \
       && grep -qx 'tree_clean=1' "$store/.seed-manifest" 2>/dev/null; then
      echo "lean push gate: green build already stored for HEAD (${head:0:12}, $slug) — skipping the gate build" >&2
      log_event gate outcome=skip repo="$(repo_identity "$root")" commit="${head:0:12}" secs=0
      exit 0
    fi
  fi

  changed="$(printf '%s\n' "$changed" | sort -u | sed '/^$/d')"
  while IFS= read -r f; do
    if [[ -n "$f" && -f "$root/$f" ]]; then touch "$root/$f"; fi
  done <<< "$changed"
  command -v lake >/dev/null 2>&1 || { echo 'lean push gate: lake not found in PATH (set SKIP_LEAN_PUSH_GATE=1 to bypass)' >&2; exit 1; }
  local n; n="$(printf '%s\n' "$changed" | grep -c . || true)"
  if [[ "$undecided" -eq 1 && "$n" -eq 0 ]]; then
    echo "lean push gate: cannot compute the changed .lean set (remote tip not fetched); running full 'lake build' (may take minutes)..." >&2
  else
    echo "lean push gate: $n changed .lean file(s); running full 'lake build' (may take minutes)..." >&2
  fi
  # Build serialized on a host slot, in a clean git environment. git push from
  # a linked worktree exports GIT_DIR/GIT_WORK_TREE into the hook (and so into
  # here); if Lake inherits them, each 'git remote get-url' it runs to validate
  # a dependency resolves against the superproject instead of the package's own
  # checkout, so Lake sees a bogus URL mismatch and tries to re-clone the
  # (read-only, cache-symlinked) package. run_lake_build scrubs the injected
  # vars so the gate build matches a plain interactive lake build.
  gate_t0="$(date +%s)"
  acquire_build_slot "lean push gate"
  run_lake_build "$root" "lean push gate" \
    || { echo 'lean push gate: lake build FAILED — push aborted (set SKIP_LEAN_PUSH_GATE=1 to bypass)' >&2; log_event gate outcome=fail repo="$(repo_identity "$root")" commit="${head:0:12}" secs=$(( $(date +%s) - gate_t0 )); exit 1; }
  log_event gate outcome=ok repo="$(repo_identity "$root")" commit="${head:0:12}" secs=$(( $(date +%s) - gate_t0 ))
  echo 'lean push gate: build OK — allowing push' >&2
  # The full build just passed, so .lake/build is a complete warm build for this
  # exact commit — capture it for reuse now. publish-build's own `lake build` is
  # an up-to-date no-op after the gate, so this is near-free. Re-exec in the
  # scrubbed environment so that no-op build behaves like the gate's, and never
  # fail the already-allowed push if publishing hits a snag.
  [[ -n "${LEAN_CACHE_NO_PUBLISH_ON_PUSH:-}" ]] || \
    ( env -u GIT_DIR -u GIT_WORK_TREE -u GIT_INDEX_FILE -u GIT_PREFIX \
        -u GIT_COMMON_DIR -u GIT_OBJECT_DIRECTORY -u GIT_QUARANTINE_PATH \
        "$BIN" publish-build "$root" ) || log "push gate: warm-build publish failed (push still allowed)"
}

# `lake build` under the shared build policy: an explicit alias for the same path
# the transparent `lake` shim takes. Warm/incremental builds run immediately with
# no slot; cold/full builds serialize on a host slot and either run to completion
# (force-wait, or a background/absent CLAUDE_BASH_MODE) or bail in a bounded
# foreground call. `--wait` forces block-to-completion regardless of mode. Extra
# args go to `lake build` verbatim.
cmd_build() {
  local wait=0 rest=()
  local a
  for a in "$@"; do
    case "$a" in
      --wait) wait=1 ;;
      *) rest+=("$a") ;;
    esac
  done
  set -- ${rest[@]+"${rest[@]}"}

  # First arg is the project path only when it looks like one (".", or contains
  # a slash) AND exists — a bare word is always a lake target, so a target that
  # happens to share its name with a directory (e.g. `build Aliasing`) is never
  # misparsed. Use ./name for a relative project dir.
  local orig=("$@") proj="."
  if [[ $# -ge 1 && ( "$1" == "." || "$1" == */* ) && -d "$1" ]]; then proj="$1"; shift; fi
  proj="$(cd "$proj" && pwd)" || die "no such directory"
  [[ -f "$proj/lakefile.toml" || -f "$proj/lakefile.lean" ]] \
    || die "$proj is not a Lake project (no lakefile)"

  [[ "$wait" -eq 1 ]] && export LEAN_CACHE_FORCE_WAIT=1
  # The command to re-run on a foreground bail: `lake build …` when we were
  # reached through the shim (what the instance actually typed), else the
  # explicit `lean-cache build …`.
  if [[ -n "${LEAN_CACHE_FROM_SHIM:-}" ]]; then
    RERUN_HINT="lake build${orig[*]:+ ${orig[*]}}"
  else
    RERUN_HINT="$PROG build${orig[*]:+ ${orig[*]}}"
  fi

  # Self-heal a broken overlay before building, so a build never has to be
  # preceded by a manual `lean-cache use`. Only fires on an actually-dangling
  # overlay (see overlay_broken) — never unconditionally, since cmd_use's own
  # seed-build can replace an incremental .lake/build the instance is mid-edit
  # on, which would be actively harmful on the common warm/incremental path.
  if overlay_broken "$proj"; then
    log "package overlay in $proj is stale (a shared-cache symlink no longer resolves); repairing"
    cmd_use "$proj"
  fi

  run_build_policied "$proj" "$PROG build" "$@"
}

# Print a one-line reminder after a commit that touches *.lean, noting the warm
# build can be published for reuse. Invoked by the post-commit hook; a quiet
# no-op on a commit that changes no *.lean.
cmd_commit_hint() {
  local root="${1:-}"
  [[ -n "$root" ]] || root="$(git rev-parse --show-toplevel 2>/dev/null)" || return 0
  local changed n
  changed="$(git -C "$root" diff-tree --no-commit-id --name-only -r --root HEAD -- '*.lean' 2>/dev/null)" || return 0
  n="$(printf '%s\n' "$changed" | grep -c . || true)"
  [[ "$n" -gt 0 ]] || return 0
  echo "lean-cache: committed changes to $n .lean file(s); run 'lean-cache publish-build' to store the warm build for reuse (a clean push publishes it automatically)." >&2
}

cmd_config() {
  [[ $# -eq 0 ]] || usage
  printf 'owner:  %s\ngroup:  %s\nroot:   %s\nbin:    %s\nbuilds: %s\n' \
    "$OWNER" "$GROUP" "$ROOT" "$BIN" "$BUILDS"
}

# Summarize the event log: read every readable events.*.log, keep events within
# the --since window, and print a compact per-event summary (counts, seed hit
# rate, gate outcomes, install/publish build durations, slot waits), split by
# user when more than one wrote. Read-only, no privilege — any user can run it.
cmd_stats() {
  local since=7
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since)   since="${2:-}"; shift 2 ;;
      --since=*) since="${1#*=}"; shift ;;
      *) usage ;;
    esac
  done
  [[ "$since" =~ ^[0-9]+$ ]] || die "--since must be a non-negative integer"

  [[ -d "$LOG_DIR" ]] || { echo "no event log at $LOG_DIR (nothing logged yet)"; return 0; }
  local now cutoff; now="$(date +%s)"; cutoff=$(( now - since * 86400 ))

  local files=() f
  for f in "$LOG_DIR"/events.*.log; do
    [[ -f "$f" && -r "$f" ]] && files+=("$f")
  done
  [[ "${#files[@]}" -gt 0 ]] || { echo "no readable event logs in $LOG_DIR"; return 0; }

  echo "lean-cache stats — last $since day(s), since $(date -d "@$cutoff" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "@$cutoff")"
  echo "logs: $LOG_DIR (${#files[@]} user file(s))"
  echo

  # One awk pass builds the whole report. median() is a self-contained insertion
  # sort (no gawk asort), fine for the small counts here. Fields are
  # tab-separated: $1 epoch, $2 user, $3 event, $4.. key=value.
  awk -F'\t' -v cutoff="$cutoff" '
    function median(a, n,   i, j, key) {
      for (i = 2; i <= n; i++) { key = a[i]; j = i - 1
        while (j >= 1 && a[j] > key) { a[j+1] = a[j]; j-- }
        a[j+1] = key }
      if (n == 0) return 0
      if (n % 2) return a[int((n+1)/2)]
      return int((a[n/2] + a[n/2+1]) / 2)
    }
    $1 !~ /^[0-9]+$/ { next }        # skip blank/garbled lines
    $1 < cutoff { next }             # outside the window
    {
      ev = $3; total[ev]++; nuser[$2] = 1; ue[$2 SUBSEP ev]++
      delete kv
      for (i = 4; i <= NF; i++) { p = index($i, "=")
        if (p) kv[substr($i, 1, p-1)] = substr($i, p+1) }
      if (ev == "seed")       { seed_t++; if (kv["hit"] == "1") seed_h++ }
      else if (ev == "gate")  { gate_t++; go[kv["outcome"]]++ }
      else if (ev == "use")   { use_t++;  if (kv["auto_install"] == "1") use_ai++ }
      else if (ev == "bail")  { bail_t++; bw[kv["where"]]++ }
      else if (ev == "install") {
        inst_t++; if (kv["ok"] == "1") inst_ok++; else inst_fail++
        if (kv["secs"] ~ /^[0-9]+$/) { v = kv["secs"]+0; inst_s[++inst_n] = v; if (v > inst_max) inst_max = v }
      }
      else if (ev == "publish") {
        pub_t++; if (kv["green"] == "1") pub_g++
        if (kv["secs"] ~ /^[0-9]+$/) { v = kv["secs"]+0; pub_s[++pub_n] = v; if (v > pub_max) pub_max = v }
      }
      else if (ev == "slot") {
        slot_t++; if (kv["outcome"] == "unserialized") slot_u++
        if (kv["wait"] ~ /^[0-9]+$/) { v = kv["wait"]+0; slot_w[++slot_n] = v; if (v > slot_max) slot_max = v }
      }
    }
    END {
      nev = 0; for (e in total) nev += total[e]
      if (nev == 0) { print "(no events in the window)"; exit }

      # Count EVERY event type generically, sorted, one line each — the
      # specialized sections below only know a fixed set, so a new/unknown event
      # type (a future kind, or one a stats build predates) must still surface
      # here rather than vanishing. Insertion sort; no gawk asorti dependency.
      nk = 0; for (e in total) evs[++nk] = e
      for (i = 2; i <= nk; i++) { key = evs[i]; j = i - 1
        while (j >= 1 && evs[j] > key) { evs[j+1] = evs[j]; j-- }
        evs[j+1] = key }

      print "events"
      for (k = 1; k <= nk; k++) { e = evs[k]; printf "  %-9s %d\n", e, total[e] }
      print ""

      if (use_t)  printf "use      %d overlaid, %d triggered an auto-install\n", use_t, use_ai+0
      if (seed_t) printf "seed     %d applicable, %d hit, %d miss (%d%% hit rate)\n", \
                          seed_t, seed_h+0, seed_t-(seed_h+0), (seed_h+0)*100/seed_t
      if (gate_t) printf "gate     %d engaged: %d ok, %d skip, %d fail\n", \
                          gate_t, go["ok"]+0, go["skip"]+0, go["fail"]+0
      if (inst_t) {
        printf "install  %d run: %d ok, %d fail", inst_t, inst_ok+0, inst_fail+0
        if (inst_n) printf "  (build secs: median %d, max %d)", median(inst_s, inst_n), inst_max+0
        print ""
      }
      if (pub_t) {
        printf "publish  %d run: %d green", pub_t, pub_g+0
        if (pub_n) printf "  (build secs: median %d, max %d)", median(pub_s, pub_n), pub_max+0
        print ""
      }
      if (slot_t) printf "slot     %d waited/degraded: median %ds, max %ds, %d unserialized\n", \
                          slot_t, (slot_n ? median(slot_w, slot_n) : 0), slot_max+0, slot_u+0
      if (bail_t) {
        printf "bail     %d:", bail_t
        for (w in bw) printf " %s=%d", w, bw[w]
        print ""
      }

      un = 0; for (u in nuser) un++
      if (un > 1) {
        print ""; print "by user"
        for (u in nuser) {
          line = ""
          for (k = 1; k <= nk; k++) { e = evs[k]; c = ue[u SUBSEP e]; if (c) line = line sprintf("  %s %d", e, c) }
          printf "  %-10s%s\n", u, line
        }
      }
    }
  ' "${files[@]}"
}

# --- Dispatch ----------------------------------------------------------------

[[ $# -ge 1 ]] || usage
cmd="$1"; shift
case "$cmd" in
  install)   cmd_install   "$@" ;;
  uninstall) cmd_uninstall "$@" ;;
  set-default-toolchain) cmd_set_default "$@" ;;
  link)      cmd_link      "$@" ;;
  use)          cmd_use           "$@" && wire_elan ;;
  refresh)      cmd_refresh       "$@" ;;
  seed-build)   cmd_seed_build    "$@" ;;
  clean)        cmd_clean         "$@" ;;
  publish-build) cmd_publish_build "$@" ;;
  build)        cmd_build         "$@" ;;
  prune-builds) cmd_prune_builds  "$@" ;;
  slots)        cmd_slots         "$@" ;;
  fix-filemode) cmd_fix_filemode  "$@" ;;
  fix-perms)    cmd_fix_perms     "$@" ;;
  pre-push-gate) cmd_pre_push_gate "$@" ;;
  commit-hint)  cmd_commit_hint   "$@" ;;
  list)      cmd_list      "$@" ;;
  resolve)   cmd_resolve   "$@" ;;
  config)    cmd_config    "$@" ;;
  check-env) cmd_check_env "$@" ;;
  verify)    cmd_verify    "$@" ;;
  stats)     cmd_stats     "$@" ;;
  -h|--help|help) usage 0 ;;
  *) die "unknown command: $cmd (try --help)" ;;
esac
