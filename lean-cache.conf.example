# lean-cache.conf — configuration for the lean-global-cache CLI and scripts.
#
# This file is sourced as plain shell by bin/lean-cache, deploy.sh, and
# admin/*.sh. It may set any subset of the variables below.
#
# A single-user cache does NOT need this file: the built-in defaults own the
# cache as the current user under their home, need no sudo, and install no lake
# shim. This file is for a shared, multi-user cache (one writer, many readers).
#
# Location — the first that exists is read (LEAN_CACHE_CONF, if set, wins and is
# used exclusively):
#   ~/.config/lean-cache/lean-cache.conf   the owner's config (per-user)
#   /etc/lean-cache/lean-cache.conf        system config (multi-user: readers
#                                          find owner/root here)
# Each setting also has an env override (LEAN_CACHE_OWNER/_GROUP/_ROOT/_BIN/
# _INSTALL_LAKE_SHIM/_LOG_DIR) that beats the file.
#
# Defaults: OWNER=current user, GROUP=current group,
#           ROOT=~/.local/share/lean-global-cache, BIN=~/.local/bin/lean-cache,
#           INSTALL_LAKE_SHIM=0.

OWNER=hostbot                 # the single writer that owns the cache
GROUP=bots
ROOT=/opt/bots/lean           # cache tree: lakes/, elan/
BIN=/opt/bots/bin/lean-cache  # install path; the sudoers re-exec target

# Install the transparent `lake` shim ahead of the real lake on PATH, so bare
# `lake build` routes through the shared build-slot policy. Off by default; set
# to 1 on a contended shared host.
INSTALL_LAKE_SHIM=1

# Append-only event log (telemetry; `lean-cache stats` reads it). Defaults to
# $ROOT/log; deploy.sh provisions it setgid+sticky so each group member writes
# only its own events.<user>.log. Uncomment to relocate.
# LOG_DIR=/opt/bots/lean/log
